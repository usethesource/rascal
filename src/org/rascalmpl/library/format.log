[3m[2m@synopsis{Extracts a path relative to a parent location.}[0m
[3m[2m@description{
* From `x:///a/b` and `x:///a/b/c` this makes `relative:///c`.
* If the outside does not envelop the inside, then the original loc is returned.
}[0m
[3m[2m@javaClass{org.rascalmpl.library.Prelude}[0m
[1mjava[0m [1mloc[0m relativize([1mloc[0m outside, [1mloc[0m inside);

[3m[2m@synopsis{Find the first `haystack` folder the `needle` can be found in and relativize it, or fail.}[0m
[3m[2m@description{
* From `[|x:///a/b|]` as haystack and `|x:///a/b/c|` as needle this makes `|relative:///c|`.
* If none of the `haystack` locations contain the `needle`, a `PathNotFound` exception is thrown.
}[0m
[1mloc[0m relativize([1mlist[0m[[1mloc[0m] haystack, [1mloc[0m needle) [1mthrows[0m PathNotFound {
    [1mif[0m (h <- haystack, [1mloc[0m r := relativize(h, needle), r != needle) {
        [1mreturn[0m r;
    }
    [1mthrow[0m PathNotFound(needle);
}

[3m[2m@synopsis{Concatenate a relative path to a given surrounding path}[0m
[3m[2m@description{
* `relative` must be of scheme `relative:///` or `SchemeNotSupported` will be thrown
* ((resolve)) is the opposite of ((relativize))
* the return value does not necessarily exist
}[0m
[1mloc[0m resolve([1mloc[0m outside, [1mloc[0m relative) = outside + relative.path
    [1mwhen[0m relative.scheme == "relative";
[1mdefault[0m [1mloc[0m resolve([1mloc[0m _, [1mloc[0m relative) {
    [1mthrow[0m SchemeNotSupported(relative);
}

[3m[2m@synopsis{Find the right folder in which a relative location is to be found and return the complete path}[0m
[3m[2m@description{
* `relative` must be of scheme `relative:///`
* ((resolve)) is the opposite of ((relativize))
* if a file can not be found in any of the `haystack` folders, then `PathNotFound`` is thrown.
* if `force` is true then a location relative to the first element of the haystack will be returned, even if the file was not found anywhere in the haystack.
}[0m
[1mloc[0m resolve(
    [1mlist[0m[[1mloc[0m] haystack,
    [1mloc[0m relative,
    [1mbool[0m force = [1mfalse[0m
) [1mthrows[0m PathNotFound {
    [1massert[0m relative.scheme == "relative";
    [1massert[0m haystack != [];
    
    [1mfor[0m ([1mloc[0m outside <- haystack, [1mloc[0m candidate := resolve(outside, relative), exists(candidate)) {
        [1mreturn[0m candidate;
    }
    
    [1mif[0m (force && haystack != []) {
        [1mreturn[0m resolve(haystack[0], relative);
    }
    [1mthrow[0m PathNotFound(relative);
}

