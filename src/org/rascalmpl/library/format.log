    prods = {p| /Production p: prod(_, _, _) := g};
    
    [3m[2m// first we fuse the attributes (SDF2 semantics) and the cons names[0m
    [1msolve[0m(prods) {
        [1mif[0m ({prod(l, r, a1), prod(l, r, a2), *rest} := prods) {
            prods = {prod(l, r, a1 + a2), *rest};
        }
        [1mif[0m ({prod(label(n, l), r, a1), prod(l, r, a2), *rest} := prods) {
            prods = {prod(label(n, l), r, a1 + a2), *rest};
        }
        [1mif[0m ({prod(label(n, l), r, a1), prod(label(_, l), r, a2), *rest} := prods) {
            prods = {prod(label(n, l), r, a1 + a2), *rest};
        }
    }
    
    [3m[2m// now we replace all uses of prods by their fused counterparts[0m
    g = [1mvisit[0m(g) {
            [1mcase[0m prod(l, r, _):
                [1mif[0m ({p: prod(l, r, _), *_} := prods)
                    [1minsert[0m p;
                [1melse[0m [1mif[0m ({p: prod(label(_, l), r, _), *_} := prods)
                    [1minsert[0m p;
                [1melse[0m
                    [1mfail[0m;
            [1mcase[0m prod(label(_, l), r, _):
                [1mif[0m ({p: prod(label(_, l), r, _), *_} := prods)
                    [1minsert[0m p;
                [1melse[0m
                    [1mfail[0m;
        }
    
    [1mreturn[0m g;
}

