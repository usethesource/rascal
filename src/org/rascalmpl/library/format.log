[3m[2m@synopsis{Specification to test the quality of M3 models that specific language front-ends produce.}[0m
[3m[2m@description{
Based on the language agnostic relations in the M3 model, this function tries to validate the
_internal_ consistency of an M3 model. 

If an M3 instance is a `closedWorld` model, this means that there are no `uses` in the model that 
are not declared in the current model in `declarations`. A closed world model allows for more
stringent consistency checks than a model that depends on external declarations. By selecting
`closedWorld=true` those additional checks are enabled, otherwise these are ignored or weakened
accordingly. It is advisable to provide at least one closed model per programming language front-end,
while testing against this spec.

By `covering` we mean that everything that is declared in the model is also used at least once.
This is a simple check for knowing if the test covers the language in some form.
}[0m
[3m[2m@benefits{
* Front-end construction is tricky business. This test provides a sanity check before users start depending
on faulty models.
}[0m
[3m[2m@pitfalls{
* In `closedWorld` many things can be strictly checked, but in an open world with dependencies outside
of the current model the validation is much weaker.
}[0m
[1mbool[0m m3SpecificationTest(M3 m, [1mbool[0m closedWorld = [1mfalse[0m, [1mbool[0m covering = [1mfalse[0m) {
    decls = m.declarations<name>;
    uses = m.uses<name>;
    externals = uses [1m-[0m decls;
    
    [3m[2m// At least one language is represented[0m
    [1massert[0m m.languages != {};
    
    [3m[2m// What `closedWorld` means:[0m
    [1massert[0m closedWorld ==> externals == {};
    
    [3m[2m// We now merge the implicitDeclarations with the externals for the sake of brevity[0m
    externals += m.implicitDeclarations;
    
    [3m[2m// Nothing that is contained here does not not have a declaration, except the outermost translationUnit[0m
    [1massert[0m decls [1m-[0m m.containment<to> [1m-[0m top(m.containment) == {};
    
    [3m[2m// Note that one declaration may occur twice ore more in the m.declarations relation.[0m
    [3m[2m// this is because of _overloading_ of names in programming languages, or because[0m
    [3m[2m// of dynamic name resolution (for languages where static name resolution is inherently inaccurate).[0m
    overloadedDeclarations = {d| d <- decls, {_, _, *_} := m.declarations[d]};
    
    [3m[2m// Containment is 1-to-many, so a reverse lookup always produces a singleton.[0m
    [3m[2m// An exception must be made for the overloaded declarations that might be contained in different elements at the same time.[0m
    [1mrel[0m[[1mloc[0m inner, [1mloc[0m outer] reverseContainment = m.containment<to,from>;
    [1massert[0m {inner
           | inner <- reverseContainment<inner>, {_} !:= reverseContainment[inner]
           }
           [1m-[0m
           overloadedDeclarations == {};
    
    [3m[2m// Everything in the containment relation has been declared somewhere[0m
    [1massert[0m carrier(m.containment) [1m-[0m decls [1m-[0m externals == {};
    
    [3m[2m// Everything in the declarations relation is contained somewhere[0m
    [1massert[0m decls [1m-[0m carrier(m.containment) == {};
    
    [3m[2m// All uses point to actual declarations[0m
    [1massert[0m uses [1m-[0m decls [1m-[0m externals == {};
    
    [3m[2m// In this example, all declarations are used at least once[0m
    [1mif[0m (covering) {
        [1massert[0m decls [1m-[0m uses == {};
    }
    [3m[2m// M.declarations is one-to-one[0m
    [1massert[0m size(decls) == size(m.declarations);
    
    [3m[2m// documentation is on names, not sources[0m
    [1massert[0m m.documentation<definition> [1m-[0m decls == {};
    
    [3m[2m// modifiers is on names, not sources[0m
    [1massert[0m m.modifiers<definition> [1m-[0m decls == {};
    
    [3m[2m// types is on names, not sources[0m
    [1massert[0m m.types<name> [1m-[0m decls [1m-[0m externals == {};
    
