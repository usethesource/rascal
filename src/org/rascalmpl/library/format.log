[1mpublic[0m Grammar grammar([1mset[0m[Symbol] starts, [1mset[0m[Production] prods) {
    [1mmap[0m[Symbol, Production] rules = ();
    
    [1mfor[0m (p <- prods) {
        t = (p.def [1mis[0m label) ? p.def.symbol : p.def;
        
        [1mif[0m (t [1min[0m rules) {
