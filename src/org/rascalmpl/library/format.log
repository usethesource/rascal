[1mdata[0m Node ([1mmap[0m[[1mstr[0m key, [1mstr[0m val] attrs = ())
    = document(Node root)
    | attribute(Namespace namespace, [1mstr[0m name, [1mstr[0m text)
    | element(Namespace namespace, [1mstr[0m name, [1mlist[0m[Node] children)
    | charData([1mstr[0m text)
    | cdata([1mstr[0m text)
    | comment([1mstr[0m text)
    | pi([1mstr[0m target, [1mstr[0m text)
    | entityRef([1mstr[0m name)
    | charRef([1mint[0m code)
    ;

[1mdata[0m Namespace
    = namespace([1mstr[0m prefix, [1mstr[0m uri)
    | none()
    ;

[1mpublic[0m [1mvalue[0m implode(document(Node root)) = implode(root);
[1mpublic[0m [1mvalue[0m implode(element(Namespace _, [1mstr[0m name, [1mlist[0m[Node] kids)) {
    result = name([implode(e) | e <- kids, !(e [1mis[0m attribute)]);
    
    [1mif[0m (attribute(_, _, _) <- kids)
        result.attrs = (k: v| attribute(_, k, v) <- kids);
    [1mreturn[0m result;
}
[1mpublic[0m [1mvalue[0m implode(charData([1mstr[0m t)) = t;
[1mpublic[0m [1mvalue[0m implode(cdata([1mstr[0m t)) = t;
[1mpublic[0m [1mdefault[0m [1mvalue[0m implode(Node x) {
    [1mthrow[0m "can not implode node"(x);
}

[1mpublic[0m
Node toXML([1mnode[0m x)
    = element(
          none(),
          getName(x),
          [toXML(c) | c <- getChildren(x)]
          + [attribute(none(), "<key>", "<params[key]>")
            | params := getKeywordParameters(x), key <- params]
      );
[1mpublic[0m [1mdefault[0m Node toXML([1mvalue[0m x) = charData("<x> ");

