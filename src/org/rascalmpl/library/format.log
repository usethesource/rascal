[3m[2m@synopsis{This core workhorse mixes the graph data with the configuration to obtain a visualizable CytoScape.js data-structure.}[0m
[3m[2m@description{
This data-structure is serialized to JSON and communicated directly to initialize cytoscape.js.
The serialization is done by the generic ((lang::json::IO)) library under the hood of a ((util::Webserver)).
}[0m
[3m[2m@synopsis{Produces an overall cytoscape.js wrapper which is sent as JSON to the client side.}[0m
Cytoscape cytoscape(
    [1mlist[0m[CytoData] \data,
    CytoGraphConfig cfg = cytoGraphConfig()
)
    = cytoscape(
          elements = \data,
          style =
          [
              cytoNodeStyleOf(cfg.nodeStyle),
              cytoEdgeStyleOf(cfg.edgeStyle),
              *cfg.styles
          ],
          \layout = cfg.\layout
      );

[3m[2m@synopsis{Turns a `rel[loc from, loc to]` into a graph}[0m
[1mlist[0m[CytoData] graphData(
    [1mrel[0m[[1mloc[0m x, [1mloc[0m y] v,
    CytoGraphConfig cfg = cytoGraphConfig()
)
    = [cytodata(
           \node("<e>", label = cfg.nodeLabeler(e), editor = "<cfg.nodeLinker(e)>"),
           classes = cfg.nodeClassifier(e)
       ) | e <- {*v<x>, *v<y>}]
    + [cytodata(
           \edge("<from>", "<to>", label = cfg.edgeLabeler(from, to)),
           classes = cfg.edgeClassifier(from, to)
       ) | <from, to> <- v];

