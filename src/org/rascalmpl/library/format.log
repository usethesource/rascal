            [1mreturn[0m [1mfalse[0m;
        }
    }
    
    [3m[2m// report on all the failed attempts[0m
    [1mfor[0m (debug, jar <- jarFiles, error(msg) := parseMavenLocalRepositoryPath(jar)) {
        println(msg);
    }
    
    [1mreturn[0m [1mtrue[0m;
}

