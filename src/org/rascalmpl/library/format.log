            [1mreturn[0m label(labelName("<i>"), getSymbol(s, isLex));
        
        [1mcase[0m (Sym) `LAYOUT`:
            [1mreturn[0m \lex("LAYOUT");
        
        [1mcase[0m (Sym) `<StrCon l>`:
            [1mreturn[0m lit(unescape(l));
        
        [1mcase[0m (Sym) `<SingleQuotedStrCon l>`:
            [1mreturn[0m cilit(unescape(l));
        
        [1mcase[0m (Sym) `<Sort n>[[<{Sym ","}+ syms>]]`:
            [1mreturn[0m \parameterized-sort("<n>", separgs2symbols(syms, isLex));
        
        [1mcase[0m (Sym) `<Sym s> ?`:
            [1mreturn[0m opt(getSymbol(s, isLex));
        
        [1mcase[0m (Sym) `<Class cc>`:
            [1mreturn[0m getCharClass(cc);
        
        [1mcase[0m (Sym) `\< <Sym s> -LEX \>`:
            [1mreturn[0m getSymbol(s, [1mtrue[0m);
        
        [1mcase[0m (Sym) `\< <Sym s> -CF \>`:
            [1mreturn[0m getSymbol(s, [1mfalse[0m);
        
        [1mcase[0m (Sym) `\< <Sym s> -VAR \>`:
            [1mreturn[0m getSymbol(s, isLex);
        
        [1mcase[0m (Sym) `<Sym lhs> | <Sym rhs>`:
            [1mreturn[0m alt({getSymbol(lhs, isLex), getSymbol(rhs, isLex)});
    }
    
    [1mif[0m (isLex)
        [1mswitch[0m(sym) {
            [1mcase[0m (Sym) `<Sort n>`:
                [1mreturn[0m lex("<n>");
            
            [1mcase[0m (Sym) `<Sym s> *`:
                [1mreturn[0m \iter-star(getSymbol(s, isLex));
            
            [1mcase[0m (Sym) `<Sym s> +`:
                [1mreturn[0m \iter(getSymbol(s, isLex));
            
            [1mcase[0m (Sym) `<Sym s> *?`:
                [1mreturn[0m \iter-star(getSymbol(s, isLex));
            
            [1mcase[0m (Sym) `<Sym s> +?`:
                [1mreturn[0m \iter(getSymbol(s, isLex));
            
            [1mcase[0m (Sym) `{<Sym s> <Sym sep>} *`:
                [1mreturn[0m \iter-star-seps (
                           getSymbol(s, isLex),
                           [getSymbol(sep, isLex)]
                       );
            
            [1mcase[0m (Sym) `{<Sym s> <Sym sep>} +`:
                [1mreturn[0m \iter-seps (
                           getSymbol(s, isLex),
                           [getSymbol(sep, isLex)]
                       );
            
            [1mcase[0m (Sym) `<Sym s>?`:
                [1mreturn[0m \opt(getSymbol(s, isLex));
            
            [1mcase[0m (Sym) `(<Sym first> <Sym+ rest>)`:
                [1mreturn[0m seq([getSymbol(first, isLex)] + [getSymbol(e, isLex) | e <- rest]);
            
            [1mcase[0m (Sym) `(<Sym s>)`:
                [1mreturn[0m getSymbol(s, isLex);
            
            [1mdefault[0m:
                [1mthrow[0m "missed a case <sym>";
        }
    [1melse[0m
        [1mswitch[0m(sym) {
            [1mcase[0m (Sym) `<Sort n>`:
                [1mreturn[0m sort("<n>");
            
            [1mcase[0m (Sym) `<Sym s> *`:
                [1mreturn[0m \iter-star-seps (
                           getSymbol(s, isLex),
                           [\layouts("LAYOUTLIST")]
                       );
            
            [1mcase[0m (Sym) `<Sym s> +`:
                [1mreturn[0m \iter-seps (
                           getSymbol(s, isLex),
                           [\layouts("LAYOUTLIST")]
                       );
            
            [1mcase[0m (Sym) `<Sym s> *?`:
                [1mreturn[0m \iter-star-seps (
                           getSymbol(s, isLex),
                           [\layouts("LAYOUTLIST")]
                       );
            
            [1mcase[0m (Sym) `<Sym s> +?`:
                [1mreturn[0m \iter-seps (
                           getSymbol(s, isLex),
                           [\layouts("LAYOUTLIST")]
                       );
            
            [1mcase[0m (Sym) `{<Sym s> <Sym sep>} *`:
                [1mreturn[0m
                    \iter-star-seps (
                        getSymbol(s, isLex),
                        [\layouts("LAYOUTLIST"), getSymbol(sep, isLex), \layouts("LAYOUTLIST")]
                    );
            
            [1mcase[0m (Sym) `{<Sym s> <Sym sep>} +`:
                [1mreturn[0m
                    \iter-seps (
                        getSymbol(s, isLex),
                        [\layouts("LAYOUTLIST"), getSymbol(sep, isLex), \layouts("LAYOUTLIST")]
                    );
            
            [1mcase[0m (Sym) `(<Sym first> <Sym+ rest>)`:
                [1mreturn[0m
                    seq(
                        [getSymbol(first, isLex)]
                        + [\layouts("LAYOUTLIST"), getSymbol(e, isLex) | e <- rest]
                    );
            
            [1mcase[0m (Sym) `(<Sym first> | <Sym second>)`:
                [1mreturn[0m alt({getSymbol(first, isLex), getSymbol(second, isLex)});
            [1mcase[0m (Sym) `(<Sym single>)`:
                [1mreturn[0m getSymbol(single, isLex);
            [1mdefault[0m:
                [1mthrow[0m "missed a case <sym>";
        }
}

