[1mpublic[0m Symbol getCharClass(Class cc) {
    [1mswitch[0m(cc) {
        [1mcase[0m (Class) `[]`:
            [1mreturn[0m \char-class([]);
        
        [1mcase[0m (Class) `[<Range* ranges>]`:
            [1mreturn[0m \new-char-class([getCharRange(r) | /Range r := ranges]);
        
        [1mcase[0m (Class) `(<Class c>)`:
            [1mreturn[0m getCharClass(c);
        
        [1mcase[0m (Class) `~ <Class c>`:
            [1mreturn[0m complement(getCharClass(c));
        
        [1mcase[0m (Class) `<Class l> /\\ <Class r>`:
            [1mreturn[0m intersection(getCharClass(l), getCharClass(r));
        
        [1mcase[0m (Class) `<Class l> \\/ <Class r>`:
            [1mreturn[0m union(getCharClass(l), getCharClass(r));
        
        [1mcase[0m (Class) `<Class l> / <Class r>`:
            [1mreturn[0m difference(getCharClass(l), getCharClass(r));
        
        [1mdefault[0m:
            [1mthrow[0m "missed a case <cc>";
    }
}

