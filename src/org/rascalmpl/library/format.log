    [1massert[0m parseJSON(#[1mlist[0m[[1mint[0m], "[1,null,2]") == [1, defaultJSONNULLValues[#[1mint[0m], 2];
    [1massert[0m parseJSON(#[1mset[0m[[1mint[0m], "[1,null,2]", nulls = ()) == {1, 2};
    [1massert[0m parseJSON(#[1mset[0m[[1mint[0m], "[1,null,2]") == {1, defaultJSONNULLValues[#[1mint[0m], 2};
    
    [1mtry[0m {
