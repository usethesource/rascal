    [3m[2m// test rebinding the generic type to another unrelated type:[0m
    [1massert[0m recursiveGenericFunction(""()) == 0;
    
    [1mif[0m ([1mstr[0m _([1mvalue[0m arg) := n) {
        [3m[2m// call a recursive function, if the type resolution is not hygienic,[0m
        [3m[2m// then &T would be bound to itself or to a caller instance type[0m
        [3m[2m// which might lead to infinite instantiation cycles in vallang[0m
        [3m[2m// if not corrected for.[0m
        [1mreturn[0m 1 + recursiveGenericFunction(arg);
    }
    [1mreturn[0m 1;
}

