[3m[2m/* Gets complicated HVHV */[0m[1mprivate[0m Text HVHV(Text T, [1mint[0m s, Text a, Box A, [1mlist[0m[Box] B, Options opts, [1mint[0m m) {
    [1mint[0m h = opts.hs;
    [1mint[0m v = opts.vs;
    [1mint[0m i = opts.is;
    [1mint[0m n = h + hwidth(a);
    
    [1mif[0m (size(a) > 1) {
        [3m[2m// Multiple lines[0m
        Text T1 = \continue(A, V([]), opts, m [1m-[0m i);
        [1mreturn[0m vv(T, rvv(vskip(v), HVHV(T1, m [1m-[0m hwidth(T1), B, opts, m, H_([]))));
    }
    [1mif[0m (n <= s) {
        [3m[2m// Box A fits in current line[0m
        [1mreturn[0m HVHV(hh(lhh(T, hskip(h, opts), opts), a, opts), s [1m-[0m n, B, opts, m, H_([]));
    }
    [1melse[0m {
        n -= h;
        [3m[2m// n == size(a)[0m
        [1mif[0m (i + n < m) {
            [3m[2m// Fits in the next line, not in current line[0m
            Text T1 = \continue(A, V([]), opts, m [1m-[0m i);
            [1mreturn[0m vv(T, rvv(vskip(v), HVHV(T1, m [1m-[0m n [1m-[0m i, B, opts, m, H_([]))));
        }
        [1melse[0m {
            [3m[2m// Doesn't fit in either lines[0m
            Text T1 = \continue(A, V([]), opts, m [1m-[0m i);
            [1mreturn[0m vv(T, rvv(vskip(v), HVHV(T1, m [1m-[0m hwidth(T1), B, opts, m, H_([]))));
        }
    }
}

[1mprivate[0m Text HVHV(Text T, [1mint[0m _s, [], Options _opts, [1mint[0m _m, Box _c) = T;

[1mprivate[0m Text HVHV(Text T, [1mint[0m s, [Box head, *Box tail], Options opts, [1mint[0m m, Box c) {
    Text T1 = \continue(head, c, opts, s);
    [1mreturn[0m HVHV(T, s, T1, head, tail, opts, m);
}

[1mprivate[0m Text HVHV([], Box _, Options opts, [1mint[0m m) = [];

[1mprivate[0m
Text HVHV([1mlist[0m[Box] b: [Box head], Box _, Options opts, [1mint[0m m)
    = \continue(head, V_([]), opts, m);

[1mprivate[0m
Text HVHV([1mlist[0m[Box] b: [Box head, Box next, *Box tail], Box _, Options opts, [1mint[0m m) {
    Text T = \continue(head, V_([]), opts, m);
    [1mreturn[0m HVHV(T, m [1m-[0m hwidth(T), [next, *tail], opts, m, H_([]));
}

