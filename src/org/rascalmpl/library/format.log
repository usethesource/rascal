        [1mcase[0m prod(label([1mstr[0m n, Symbol _), [1mlist[0m[Symbol] lhs, [1mset[0m[Attr] as):
            [1mreturn[0m
                "<[1mfor[0m (a <- as) {><attr2mod(a)> <}><reserved(n)>: <[1mfor[0m (s <- lhs) {><symbol2rascal(s)> <}>";
        
        [1mcase[0m prod(Symbol _, [1mlist[0m[Symbol] lhs, {}):
            [1mreturn[0m "<[1mfor[0m (s <- lhs) {><symbol2rascal(s)> <}>";
        
        [1mcase[0m prod(Symbol _, [1mlist[0m[Symbol] lhs, [1mset[0m[Attr] as):
            [1mreturn[0m
                "<[1mfor[0m (a <- as) {><attr2mod(a)> <}><[1mfor[0m (s <- lhs) {><symbol2rascal(s)> <}>";
        
        [1mcase[0m regular(_):
            [1mreturn[0m "";
        
        [1mdefault[0m:
            [1mthrow[0m "missed a case <p>";
    }
}

