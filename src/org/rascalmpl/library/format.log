}[0m
TextEdit insertBefore([1mloc[0m range, [1mstr[0m insertion, [1mstr[0m separator = " ")
    = (range.begin?)
          ? replace(
                range.top(range.offset, 0, range.begin, range.begin),
                "<insertion><separator>"
            )
