[1mpublic[0m [1mstr[0m allTableSchemas([1mstr[0m moduleName, [1mloc[0m uri) {
    [3m[2m// This indicates which driver we need (MySQL, Oracle, etc)[0m
    driverType = uri.scheme;
    [1mif[0m (driverType [1mnotin[0m drivers)
        [1mthrow[0m "Driver not found";
    [3m[2m// The URI should include the host and the database as well. The[0m
    [3m[2m// path should just be the database name.[0m
    hostName = uri.authority;
    [1mif[0m (uri.path != "/<uri.file>")
        [1mthrow[0m "Invalid path, should just include database name";
    dbName = uri.file;
    
    [3m[2m// These are the rest of the params, which should include everything[0m
    [3m[2m// needed to connect plus some params that alter the generation[0m
    params = uri.params;
    
    [3m[2m// Now, create the connect string, based on the type of database and the[0m
    [3m[2m// parameters passed in.[0m
    params["host"] = hostName;
    params["database"] = dbName;
    connectString = connectStringGenerators[driverType](params);
    
    [3m[2m// We need to connect to get the tables that we will generate accessors for[0m
    registerJDBCClass(drivers[driverType]);
    con = createConnection(connectString);
    
    [3m[2m// Get back a list of table types, sorted by table name[0m
    ts
        = sort(
              toList(getTables(con)),
              [1mbool[0m (resource::jdbc::JDBC::Table t1, resource::jdbc::JDBC::Table t2) {
              [1mreturn[0m t1.tableName < t2.tableName;
          });
    
    [3m[2m// Then, generate the accessor function for each[0m
    [1mlist[0m[[1mstr[0m] tfuns = [];
    [1mfor[0m (Table t <- ts) {
        columnTypes
            = [nullable ? \label("\\<cn>", \adt (
                                               "NULLable",
                                               [rt]
                                           )) : \label("\\<cn>", rt)
              | table(_tn, cl) := t, column(cn, ct, nullable) <- cl, rt := jdbc2RascalType(ct)];
        columnTuple = \tuple(columnTypes);
        
        tfun
            = "alias \\<t.tableName>RowType = <format(columnTuple)>;
              'alias \\<t.tableName>Type = rel[<intercalate(",", [format(ct) | ct <- columnTypes])>];
              '
              'public \\<t.tableName>Type \\<t.tableName>() {
              '    registerJDBCClass(\"<drivers[driverType]>\");
              '    con = createConnection(\"<connectString>\");
              '    \\<t.tableName>Type res = loadTable(#<format(columnTuple)>,con,\"<t.tableName>\");
              '    closeConnection(con);
              '    return res;
              '}
              '";
        
        tfuns += tfun;
    }
    
    closeConnection(con);
    
    [3m[2m// Generate the module, which will include accessors for each table.[0m
    mbody
        = "module <moduleName>
          'import resource::jdbc::JDBC;
          '
          '<[1mfor[0m (tfun <- tfuns) {>
          '<tfun>
          '<}>
          '";
    
    [1mreturn[0m mbody;
}

