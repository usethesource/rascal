[1mprivate[0m [1mdata[0m MavenLocalRepositoryPath
    = path([1mstr[0m groupId, [1mstr[0m artifactId, [1mstr[0m version)
    | error([1mstr[0m cause)
    ;

[1mprivate[0m MavenLocalRepositoryPath parseMavenLocalRepositoryPath([1mloc[0m jar) {
    [1mif[0m (jar.extension != "jar") {
        [1mreturn[0m error("jar should have jar extension");
    }
    jar = relativize(|home:///.m2/repository|, jar);
    
    [1mstr[0m groupId = replaceAll(jar.parent.parent.parent.path[1..], "/", ".");
    [1mstr[0m artifactId = jar.parent.parent.file;
    [1mstr[0m version = jar.parent.file;
    [1mstr[0m file = jar.file;
    
    [1mif[0m (file != "<artifactId>-<version>.jar") {
        [1mreturn[0m
            error(
                "This is not a repository release jar; filename should be ArtifactId-Version.jar: <jar.file>"
            );
    }
    [1mif[0m (/!/ := artifactId) {
        [1mreturn[0m error("ArtifactId contains exclamation mark: <artifactId>");
    }
    [1mreturn[0m path(groupId, artifactId, version);
}

[1mtest[0m [1mbool[0m mvnSchemeTest() {
    debug = [1mfalse[0m;
    jarFiles = find(|home:///.m2/repository|, "jar");
    
    [3m[2m// check whether the implementation of the scheme holds the contract specified in the assert[0m
    [1mfor[0m (jar <- jarFiles, path(groupId, artifactId, version) := parseMavenLocalRepositoryPath(jar)) {
        [3m[2m// this is the contract:[0m
        [1mloc[0m mvnLoc = |mvn://< groupId >--< artifactId >--< version >|;
        
        [1mif[0m (!exists(mvnLoc)) {
