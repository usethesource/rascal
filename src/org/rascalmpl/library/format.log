                  );
        }
        [1mif[0m (first.begin? && last.end?) {
            [1mreturn[0m
                first.top(
                    first.offset,
                    last.offset + last.length [1m-[0m first.offset,
                    <first.begin.line, first.begin.column>,
                    <last.end.line, last.end.column>
