[1mpublic[0m [1mdata[0m ParseBenchmarkConfig
    = parseBenchmarkConfig(
          [1mloc[0m syntaxFile = |std:///lang/rascal/syntax/Rascal.rsc|,
          [1mstr[0m topSort = "Module",
          [1mstr[0m extension = ".rsc",
          [1mloc[0m files = |unknown:///|,
          [1mloc[0m statFile = |tmp:///parse-benchmark-stats.csv|,
          [1mint[0m warmupIterations = 100,
          [1mint[0m parseIterations = 10);

[1mlist[0m[[1mloc[0m] gatherFiles([1mloc[0m dir, [1mstr[0m ext) {
    [1mlist[0m[[1mloc[0m] files = [];
    [1mfor[0m (entry <- listEntries(dir)) {
        [1mloc[0m file = dir + entry;
        [1mif[0m (isFile(file)) {
            [1mif[0m (endsWith(file.path, ext)) {
                files += file;
            }
        }
        [1melse[0m
            [1mif[0m (isDirectory(file)) {
                files += gatherFiles(file, ext);
            }
    }
    
    [1mreturn[0m files;
}

[1mprivate[0m
[1mvoid[0m warmupParser(
    &T([1mvalue[0m input, [1mloc[0m origin) benchmarkParser, [1mlist[0m[[1mloc[0m] files, [1mint[0m iterations
) {
    println("Warming up parser (<iterations>)");
    [1mfor[0m ([1mint[0m i <- [0..iterations]) {
        [1mloc[0m file = files[i % size(files)];
        [1mtry[0m {
            benchmarkParser(readFile(file), file);
        }
        [1mcatch[0m ParseError(_): {
            println("Skipping warmup for file with parse errors: <file>");
        }
    }
}

[1mprivate[0m
[1mvoid[0m runBenchmark(
    ParseBenchmarkConfig config, &T([1mvalue[0m input, [1mloc[0m origin) benchmarkParser,
    [1mloc[0m file
) {
    println("Benchmarking <file>");
    [1mstr[0m content = readFile(file);
    [1mint[0m contentSize = size(content);
    [1mint[0m iterations = config.parseIterations;
    [1mint[0m i = 0;
    [1mtry[0m {
        [1mint[0m begin = realTime();
        [1mwhile[0m(i < iterations) {
            benchmarkParser(content, file);
            i += 1;
        }
        [1mint[0m duration = realTime() [1m-[0m begin;
        
        appendToFile(config.statFile, "<file>,<contentSize>,<duration>\n");
    }
    [1mcatch[0m ParseError(_): {
        println("Ignoring file with parse errors: <file>");
    }
}

[1mprivate[0m
[1mvoid[0m runBenchmark(
    ParseBenchmarkConfig config, &T([1mvalue[0m input, [1mloc[0m origin) benchmarkParser,
    [1mlist[0m[[1mloc[0m] files
) {
    [1mfor[0m ([1mloc[0m file <- files) {
        runBenchmark(config, benchmarkParser, file);
    }
}

[1mprivate[0m [1mstr[0m syntaxLocToModuleName([1mloc[0m syntaxFile) {
    [1mstr[0m path = replaceLast(substring(syntaxFile.path, 1), ".rsc", "");
    [1mreturn[0m replaceAll(path, "/", "::");
}

[1mprivate[0m [1mvoid[0m benchmark(ParseBenchmarkConfig config) {
    writeFile(config.statFile, "input,size,duration\n");
    Module \module = parse(#[1mstart[0m[Module], config.syntaxFile).top;
    [1mstr[0m modName = syntaxLocToModuleName(config.syntaxFile);
    Grammar gram = modules2grammar(modName, {\module});
    
    [1mstr[0m topSort = config.topSort;
    [1mif[0m (sym: \start(\sort(topSort)) <- gram.starts) {
        [1mtype[0m[[1mvalue[0m] begin = [1mtype[0m(sym, gram.rules);
        benchmarkParser = parser(begin);
        [1mlist[0m[[1mloc[0m] files = gatherFiles(config.files, config.extension);
        
        warmupParser(benchmarkParser, files, config.warmupIterations);
        runBenchmark(config, benchmarkParser, files);
    }
    [1melse[0m {
        [1mthrow[0m "Cannot find top sort <topSort> in <gram>";
    }
}

[1mint[0m main([1mlist[0m[[1mstr[0m] args) {
    ParseBenchmarkConfig config = parseBenchmarkConfig();
    
    [1mfor[0m ([1mstr[0m arg <- args) {
        [1mif[0m (/<name:[^=]*>=<val:.*>/ := arg) {
            [1mswitch[0m(toLowerCase(name)) {
                [1mcase[0m "syntax":
                    config.syntaxFile = readTextValueString(#[1mloc[0m, val);
                [1mcase[0m "sort":
                    config.topSort = val;
                [1mcase[0m "files":
                    config.files = readTextValueString(#[1mloc[0m, val);
                [1mcase[0m "ext":
                    config.extension = val;
                [1mcase[0m "stats":
                    config.statFile = readTextValueString(#[1mloc[0m, val);
                [1mcase[0m "warmup":
                    config.warmupIterations = toInt(val);
                [1mcase[0m "parses":
                    config.parseIterations = toInt(val);
            }
        }
    }
    
    benchmark(config);
    
    [1mreturn[0m 0;
}

