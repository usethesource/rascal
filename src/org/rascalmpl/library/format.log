[3m[2m// Simulate a list of 1000 lines each of length < 1000;[0m
[1mpublic[0m [1mlist[0m[[1mint[0m] lineSizes = [arbInt(1000) | [1mint[0m _ <- [1..1000]] ;

[1mpublic[0m [1mint[0m maxIndex = ( 0 | [1mit[0m + lineSizes[i] | [1mint[0m i <- index(lineSizes) ) ;

[3m[2m// Turn an index in the above list into a line/column pair[0m
[1mtuple[0m[[1mint[0m line, [1mint[0m column] getLineAndColumn([1mint[0m idx) {
    [1mint[0m pos = 0;
    
    [1mfor[0m ([1mint[0m i <- index(lineSizes)) {
        [1mif[0m (pos + lineSizes[i] >= idx)
            [1mreturn[0m <i, idx [1m-[0m pos>;
        pos += lineSizes[i];
    }
    [1mthrow[0m "getLineAndColumn: <idx> out of range [0 .. <maxIndex>]";
}

[3m[2m// Build a location for an area from index f to index t.[0m
[1mloc[0m buildLoc([1mint[0m f, [1mint[0m t, [1mstr[0m base = "base.src") {
    [1mreturn[0m
        |test:///< base >|(f, t [1m-[0m f, getLineAndColumn(f), getLineAndColumn(t));
}

[3m[2m// Restrict i to legal index values[0m
[1mint[0m restrict([1mint[0m i) {
    [1mif[0m (i < 0)
        i = [1m-[0mi;
    [1mif[0m (i > maxIndex)
        [1mreturn[0m arbInt(maxIndex);
    [1mreturn[0m i;
}

[3m[2m// Get a location from index f to index t.[0m
[1mloc[0m getLoc([1mint[0m f, [1mint[0m t, [1mstr[0m base = "base.src") {
    f = restrict(f);
    t = restrict(t);
    [1mreturn[0m (f <= t) ? buildLoc(f, t, base = base) : buildLoc(t, f, base = base);
}

[3m[2m// Test the comparison operators[0m
[1mtest[0m [1mbool[0m less1([1mint[0m f1, [1mint[0m t1, [1mint[0m f2, [1mint[0m t2) {
    l1 = getLoc(f1, t1);
    l2 = getLoc(f2, t2);
    [1mreturn[0m
        l1.offset > l2.offset
