    [1mstr[0m ESC = "\a1b[";
    [1mstr[0m Bold = "<ESC>1m";
    [1mstr[0m Underline = "<ESC>4m";
    [1mstr[0m Normal = "<ESC>0m";
    [1mstr[0m Comment = "<ESC>3m<ESC>2m";
    [1mstr[0m bold([1mstr[0m s) = "<Bold><s><Normal>";
    [1mstr[0m underline([1mstr[0m s) = "<Underline><s><Normal>";
