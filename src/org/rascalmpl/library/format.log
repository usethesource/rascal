                  plugins =
                  chartPlugins(
                      legend = chartLegend(position = top(), display = legend),
                      title = chartTitle(display = [1mtrue[0m, text = title),
                      colors = chartColors(enabled = [1mtrue[0m),
                      autocolors = chartAutoColors(mode = colorMode)
