[3m[2m@synopsis{This function wraps productions with their single character lookahead sets for 
  parser generation.
  
  'extra' contains extra lookahead symbols per symbol}[0m
[1mpublic[0m Grammar computeLookaheads(Grammar G, [1mrel[0m[Symbol, Symbol] extra) {
    G2 = expandRegularSymbols(removeLabels(G));
    <fst, fol>
        = firstAndFollow(simple(G2.starts, {p| /Production p: prod(_, _, _) := G2}));
    
    [1mreturn[0m
        [1mvisit[0m(G) {
            [1mcase[0m Production p: prod(Symbol rhs, [], _) => lookahead(rhs, fol[rhs], p)
            [1mcase[0m Production p: prod(Symbol rhs, [1mlist[0m[Symbol] lhs, _): {
                lhs = removeLabels(lhs);
                
                classes = first(lhs, fst);
                
                [1mif[0m (lhs == [] || empty() [1min[0m classes)
                    classes += fol[rhs];
                classes -= empty();
                
                [3m[2m// merge the character classes and construct a production wrapper[0m
                [1minsert[0m lookahead(rhs, mergeCC(classes + extra[rhs]), p);
