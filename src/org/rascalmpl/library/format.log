[1mint[0m fingerprint([1mint[0m r) = hash == 0 ? internalHashCode("int") : hash
    [1mwhen[0m [1mint[0m hash := internalHashCode(r);
[1mint[0m fingerprint([1mreal[0m r) = hash == 0 ? internalHashCode("real") : hash
    [1mwhen[0m [1mint[0m hash := internalHashCode(r);
[1mint[0m fingerprint([1mrat[0m r) = hash == 0 ? internalHashCode("rat") : hash
    [1mwhen[0m [1mint[0m hash := internalHashCode(r);
[1mint[0m fingerprint([1mvalue[0m t) = tupleFingerprint(size(fields))
