[1mpublic[0m [1mset[0m[Production] getProduction(Prod P, [1mbool[0m isLex) {
    [1mswitch[0m(P) {
        [1mcase[0m (Prod) `<Syms syms> -\> LAYOUT <Attrs ats>`:
            [1mreturn[0m
                {prod(layouts("LAYOUTLIST"), [\iter-star(\lex("LAYOUT"))], {}),
                 prod(\lex("LAYOUT"), getSymbols(syms, isLex), getAttributes(ats))};
        [1mcase[0m (Prod) `<Syms syms> -\> <Sym sym> {<{Attribute ","}* _>, reject, <{Attribute ","}* _> }`:
            [1mreturn[0m
                {prod(
                     keywords(getSymbol(sym, isLex).name + "Keywords"),
                     getSymbols(syms, isLex),
                     {}
                 )};
        [1mcase[0m (Prod) `<Syms syms> -\> <Sym sym> {<{Attribute ","}* x>, cons(<StrCon n>), <{Attribute ","}* y> }`:
            [1mreturn[0m
                {prod(
                     label(labelName(unescape(n)), getSymbol(sym, isLex)),
                     getSymbols(syms, isLex),
                     getAttributes(
                         (Attrs) `{<{Attribute ","}* x>, <{Attribute ","}* y> }`
                     )
                 )};
        [1mcase[0m (Prod) `<Syms syms> -\> <Sym sym> <Attrs ats>`:
            [1mreturn[0m
                {prod(getSymbol(sym, isLex), getSymbols(syms, isLex), getAttributes(ats))};
        [1mdefault[0m: {
            println("WARNING: not importing <P>");
            [1mreturn[0m {prod(sort("IGNORED"), [], {\tag("NotSupported"("<P>"))})};
        }
    }
}

