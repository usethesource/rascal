                [3m[2m// Successor w is in stack S and hence in the current SCC[0m
                [3m[2m// If w is not on stack, then (v, w) is a cross-edge in the DFS tree and must be ignored[0m
               low[v] = min(low[v], indexOf[w]);
            }
         }
         
        [3m[2m// If v is a root node, pop the stack and generate an SCC[0m
        [1mif[0m(low[v] == indexOf[v]){
            [3m[2m// Start a new strongly connected component[0m
            scc = {};
            &T w = v;
            [1mdo[0m {
                <w, stack> = pop(stack);
                onStack -= {w};
                scc += {w};
                topsort = [w] + topsort;
            } [1mwhile[0m (w != v);
            components += {scc};
        }
    }
    
    [1mfor[0m(v <- carrier(g)){
        [1mif[0m(!indexOf[v]?){
            strongConnect(v);
        }
    }
    
    [1mreturn[0m <components, topsort>;
}


