[3m[2m// Create a list of n different locations[0m
[1mlist[0m[[1mloc[0m] getLocs([1mint[0m n) {
    locs = [getLoc(arbInt(maxIndex), arbInt(maxIndex)) | [1mint[0m _ <- [0..n]];
    [1mreturn[0m
        [locs[i] | [1mint[0m i <- [0..n], ![1many[0m([1mint[0m j <- [0..n], i != j, locs[i] == locs[j])];
}

