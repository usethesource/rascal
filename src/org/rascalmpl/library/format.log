[1mprivate[0m Text VV([], Box _c, Options _opts, [1mint[0m _m) = [];

[1mprivate[0m Text VV([1mlist[0m[Box] b: [_, *_], Box c, Options opts, [1mint[0m m) {
    Text r = [];
    b = reverse(b);
    [1mfor[0m (a <- b) {
        [1mif[0m (V_(_) !:= c || L("") !:= a) {
