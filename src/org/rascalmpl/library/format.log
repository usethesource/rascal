```
}[0m
[1mpublic[0m [1mset[0m[[1mset[0m[&T]] power([1mset[0m[&T] st) {
    [3m[2m// the power set of a set of size n has 2^n-1 elements[0m
    [3m[2m// so we enumerate the numbers 0..2^n-1[0m
    [3m[2m// if the nth bit of a number i is 1 then[0m
    [3m[2m// the nth element of the set should be in the[0m
    [3m[2m// ith subset[0m
    stl = [*st];
    i = 0;
    res = [1mwhile[0m(i < pow(2, size(st))) {
              j = i;
              elIndex = 0;
              sub = [1mwhile[0m(j > 0) {
                        ;
                        [1mif[0m (j [1mmod[0m 2 == 1) {
                            [1mappend[0m stl[elIndex];
                        }
                        elIndex += 1;
                        j /= 2;
                    }
              [1mappend[0m {*sub};
              i += 1;
          }
    [1mreturn[0m {*res};
}

