### |project://rascal/src/org/rascalmpl/library/lang/rascal/vis/ImportGraph.rsc|
[3m[2m@synopsis{Visualize the import and extend structure of a Rascal project using a hierarchical graph layout}[0m
[3m[2m@description{
The so-called "import graph" for Rascal modules stems from the times of the ASF+SDF Meta-Environment.
There it was the core UI for interacting with a loaded modular language specification. We recreated
it here for Rascal, but in an on-demand fashion. You can look at the import graph but it is not kept up-to-date
with the state of the files in the IDE. It is more of a snapshot of the current situation.
}[0m
[3m[2m@benefits{
* A visual representation can help avoid overly complex dependencies, including unnecessary cycles.
* Visual analysis may help get an overview of a complex Rascal application.
* Modular and extensible language implementations often provide nice pictures where each layer
is clearly visible.
}[0m
[3m[2m@pitfalls{
* The visualization is a static snapshot and does not change automatically when files are saved.
}[0m
[3m[2m@bootstrapParser[0m
[1mmodule[0m lang::rascal::vis::ImportGraph

[1mimport[0m util::Reflective;
[1mimport[0m vis::Graphs;
[1mimport[0m lang::rascal::grammar::definition::Modules;
[1mimport[0m lang::rascal::\syntax::Rascal;
[1mimport[0m Exception;
[1mimport[0m util::FileSystem;
[1mimport[0m util::IDEServices;
[1mimport[0m IO;
[1mimport[0m analysis::graphs::Graph;
[1mimport[0m Set;

[3m[2m@synopsis{If `projectName` is an open project in the current IDE, the visualize its import/extend graph.}[0m
[1mvoid[0m importGraph([1mstr[0m projectName, [1mbool[0m hideExternals = [1mtrue[0m) {
    importGraph(|project://< projectName >|, hideExternals = hideExternals);
}

[3m[2m@synopsis{Given an arbitrary root folder of a Rascal project, visualize its import/extend graph.}[0m
[1mvoid[0m importGraph([1mloc[0m projectRoot, [1mbool[0m hideExternals = [1mtrue[0m) {
    [3m[2m// we use compiler() mode here to avoid diving into the transitively depended projects.[0m
    pcfg = getProjectPathConfig(projectRoot, mode = compiler());
    importGraph(pcfg, hideExternals = hideExternals);
}

[3m[2m@synopsis{Visualizes an import/extend graph for all the modules in the srcs roots of the current PathConfig}[0m
[1mvoid[0m importGraph(PathConfig pcfg, [1mbool[0m hideExternals = [1mtrue[0m) {
    m = getProjectModel(pcfg.srcs);
    
    [3m[2m// let's start with a simple graph and elaborate on details in later versions[0m
    g
        = {<from, to>
          | <from, to> <- sort(m.imports), hideExternals ==> to [1mnotin[0m m.external
          }
        + {<from, to>
          | <from, to> <- sort(m.extends), hideExternals ==> to [1mnotin[0m m.external
          }
        + {<"_", to>| to <- top(m.imports + m.extends)}[3m[2m// pull up the top modules[0m
                                                       ;
    
    [1mlist[0m[[1mstr[0m] nodeClass([1mstr[0m n)
        = [*["external" | n [1min[0m m.external], *["project" | n [1mnotin[0m m.external]];
    
    gClosed = g+;
    
    [1mlist[0m[[1mstr[0m] edgeClass([1mstr[0m from, [1mstr[0m to)
        = [
              *["extend" | <from, to> [1min[0m m.extends],
              *["import" | <from, to> [1min[0m m.imports],
              *["transitive"
               | <from, to> [1min[0m g [1mo[0m gClosed, <from, from> [1mnotin[0m gClosed, <to, to> [1mnotin[0m gClosed],
              *["cyclic" | <from, from> [1min[0m gClosed]
          ];
    
    styles
        = [
              cytoStyleOf(
                  selector = \edge(equal("source", "_")),
                  style = defaultEdgeStyle()[visibility = "hidden"]
              ),
              cytoStyleOf(
                  selector = \node(id("_")), style = defaultNodeStyle()[visibility = "hidden"]
              ),
              cytoStyleOf(
                  selector = \edge(className("extend")),
                  style = defaultEdgeStyle()[\line-style = "dashed"]
              ),
              cytoStyleOf(
                  selector = \edge(className("transitive")),
                  style = defaultEdgeStyle()[opacity = ".25"][\line-opacity = "0.25"]
              ),
              cytoStyleOf(
                  selector = \edge(className("cyclic")),
                  style = defaultEdgeStyle()[opacity = "1"][\line-opacity = "1"][\width = 10]
              )
          ];
    
    [1mloc[0m modLinker([1mstr[0m name) {
        [1mif[0m ([1mloc[0m x <- m.files[name])
            [1mreturn[0m x;
        [1melse[0m
            [1mreturn[0m |nothing:///|;
    }
    
    [1mdefault[0m [1mloc[0m modLinker([1mvalue[0m _) = |nothing:///|;
    
    cfg
        = cytoGraphConfig(
              \layout = defaultDagreLayout()[ranker = \network-simplex()],
              styles = styles,
              title = "Rascal Import/Extend Graph",
              nodeClassifier = nodeClass,
              edgeClassifier = edgeClass,
              nodeLinker = modLinker,
              edgeStyle = defaultEdgeStyle()[\curve-style = taxi()]
          );
    
    showInteractiveContent(graph(g, cfg = cfg), title = cfg.title);
}

[3m[2m@synopsis{Container for everything we need to know about the modules in a project to visualize it.}[0m
[1mdata[0m ProjectModel
    = projectModel(
          [1mset[0m[[1mstr[0m] modules = {},
          [1mset[0m[[1mstr[0m] external = {},
          [1mrel[0m[[1mstr[0m, [1mstr[0m] imports = {},
          [1mrel[0m[[1mstr[0m, [1mstr[0m] extends = {},
          [1mrel[0m[[1mstr[0m, [1mloc[0m] files = {});

[3m[2m@synopsis{Collects name, imports and extends for all modules reachable from the `srcs` root folders.}[0m
ProjectModel getProjectModel([1mlist[0m[[1mloc[0m] srcs) {
    allFiles = {*find(src, "rsc")| src <- srcs};
    
    models = {getProjectModel(f)| f <- allFiles};
    
    wholeWorld
        = projectModel(
              modules = {*m.modules| m <- models},
              imports = {*m.imports| m <- models},
              extends = {*m.extends| m <- models},
              files = {*m.files| m <- models}
          );
    
    wholeWorld.external
        = wholeWorld.imports<1> + wholeWorld.extends<1> [1m-[0m wholeWorld.modules;
    
    [1mreturn[0m wholeWorld;
}

[3m[2m@synopsis{Collects name, imports and extends for a single Rascal module}[0m
ProjectModel getProjectModel([1mloc[0m file) {
    [1mtry[0m {
        Module m = parseModule(file);
        
        <name, imps, exts> = getModuleMetaInf(m);
        
        [1mreturn[0m
            projectModel(
                modules = {name},
                imports = {name} * imps,
                extends = {name} * exts,
                files = {<name, file >}
            );
    }
    [1mcatch[0m ParseError(_):
        [1mreturn[0m projectModel();
}
