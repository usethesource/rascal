### |project://rascal/src/org/rascalmpl/library/analysis/diff/edits/HiFiLayoutDiff.rsc|
[3m[2m@synopsis{Compare equal-modulo-layout parse trees and extract the exact whitespace text edits that will format the original file.}[0m
[3m[2m@description{
This algorithm is the final component of a declarative high fidelity source code formatting pipeline.

We have the following assumptions:
1. One original text file exists.
2. One ((ParseTree)) of the original file to be formatted, containing all original layout and source code comments and case-insensitive literals in the exact order of the original text file. In other words,
nothing may have happened to the parse tree after parsing.
3. One ((ParseTree)) of the _same_ file, but formatted (using a formatting algorithm like ((Tree2Box)) `|` ((Box2Text)), or string templates, and then re-parsing). This is typically obtained by
translating the tree to a `str` using some formatting tools, and then reparsing the file.
4. Typically comments and specific capitalization of case-insensitive literals have been lost in step 3.
5. We use ((analysis::diff::edits::TextEdits)) to communicate the effect of formatting to the IDE context.
}[0m
[3m[2m@pitfalls{
* if `originalTree !:= formattedTree` the algorithm will produce junk. It will break the syntactical correctness of the source code and forget source code comments.
* if comments are not marked with `@category("Comment")` in the original grammar, then this algorithm can not recover them.
}[0m
[3m[2m@benefits{
* Recovers source code comments which have been lost during earlier steps in the formatting pipeline. This makes losing source code comments an independent concern of a declarative formatter.
* Recovers the original capitalization of case-insensitive literals which may have been lost during earlier steps in the formatting pipeline.
* Can standardize the layout of case insensitive literals to ALLCAPS, all lowercase, or capitalized. Or can leave the literal as it was formatted by an earlier stage.
* Is agnostic towards the design of earlier steps in the formatting pipeline, so lang as `formattedTree := originalTree`. This means that
the pipeline may change layout (whitespace and comments and capitalization of case-insensitive literals), but nothing else.
}[0m
[1mmodule[0m analysis::diff::edits::HiFiLayoutDiff

[1mextend[0m analysis::diff::edits::HiFiTreeDiff;
[1mimport[0m ParseTree;
[3m[2m// this should not be necessary because imported by HiFiTreeDiff[0m
[1mimport[0m String;
[3m[2m// this should not be be necessary because imported by HiFiTreeDiff[0m
[1mimport[0m lang::rascal::grammar::definition::Characters;
[1mimport[0m IO;

[3m[2m@synopsis{Normalization choices for case-insensitive literals.}[0m
[1mdata[0m CaseInsensitivity
    = toLower()
    | toUpper()
    | toCapitalized()
    | asIs()
    | asFormatted()
    ;

[3m[2m@synopsis{Extract TextEdits for the differences in whitespace between two otherwise identical ((ParseTree))s.}[0m
[3m[2m@description{
See ((HiFiLayoutDiff)).
}[0m
[1mlist[0m[TextEdit] layoutDiff(
    Tree original,
    Tree formatted,
    [1mbool[0m recoverComments = [1mtrue[0m,
    CaseInsensitivity ci = asIs()
) {
    [1massert[0m
    original := formatted
    : "nothing except layout and keyword fields may be different for layoutDiff to work correctly. <treeDiff(original, formatted)>";
    
    [3m[2m@synopsis{rec is the recursive workhorse, doing a pairwise recursion over the original and the formatted tree}[0m
    [3m[2m@description{
        We recursively skip over every "equal" pairs of nodes, until we detect two different _layout_ nodes. The original location
        of that node and the new contents of the formatted node is used to construct a replace ((TextEdit)), and 
        optionally the original layout is inspected for source code comments which may have been lost. Literals are skipped 
        explicitly to avoid arbitrary edits for case insensitive literals, and to safe some time.
    }[0m
    [3m[2m// if layout differences are detected, here we produce a `replace` node:[0m
    [1mlist[0m[TextEdit] rec(
        t: appl(prod(Symbol tS, _, _), [1mlist[0m[Tree] tArgs),
        [3m[2m// layout is not necessarily parsed with the same rules (i.e. comments are lost!)[0m
        u: appl(prod(Symbol uS, _, _), [1mlist[0m[Tree] uArgs)
    )
        = [replace(t@\loc, repl)
          | tArgs != uArgs, [1mstr[0m repl := (recoverComments ? learnComments(t, u) : "<u>"), repl != "<t>"[3m[2m/* do not edit anything if nothing has changed */[0m                                                                                                      ]
        [1mwhen[0m delabel(tS) [1mis[0m layouts, delabel(uS) [1mis[0m layouts, tArgs != uArgs;
    
    [3m[2m// matched literal trees generate empty diffs[0m
    [1mlist[0m[TextEdit] rec(
        appl(prod(lit(_), _, _), [1mlist[0m[Tree] _), appl(prod(lit(_), _, _), [1mlist[0m[Tree] _)
    )
        = [];
    
    [3m[2m// matched case-insensitive literal trees generate empty diffs such that the original is maintained.[0m
    [3m[2m// however, we also offer some convenience functionality to standardize their formatting right here.[0m
    [1mlist[0m[TextEdit] rec(
        t: appl(prod(cilit(_), _, _), [1mlist[0m[Tree] _),
        u: appl(prod(cilit(_), _, _), [1mlist[0m[Tree] _)
    ) {
        [1mstr[0m yield = "<t>";
        
        [1mswitch[0m(ci) {
            [1mcase[0m asIs():
                [1mreturn[0m [];
            [1mcase[0m asFormatted():
                [1mreturn[0m [replace(t@\loc, result) | [1mstr[0m result := "<u>", result != yield];
            [1mcase[0m toUpper():
                [1mreturn[0m
                    [replace(t@\loc, result) | [1mstr[0m result := toUpperCase(yield), result != yield];
            [1mcase[0m toLower():
                [1mreturn[0m
                    [replace(t@\loc, result) | [1mstr[0m result := toLowerCase(yield), result != yield];
            [1mcase[0m toCapitalized():
                [1mreturn[0m
                    [replace(t@\loc, result) | [1mstr[0m result := capitalize(yield), result != yield];
            [1mdefault[0m:
                [1mthrow[0m "unexpected option: <ci>";
        }
    }
    
    [1mlist[0m[TextEdit] rec(char(_), char(_)) = [];
    
    [1mlist[0m[TextEdit] rec(cycle(Symbol _, [1mint[0m _), cycle(_, _)) = [];
    
    [3m[2m// recurse through the entire parse tree to collect layout edits:[0m
    [1mdefault[0m [1mlist[0m[TextEdit] rec(
        Tree t: appl(Production p, [1mlist[0m[Tree] argsA), appl(p[3m[2m/* must be the same by the above assert */[0m                                                            , [1mlist[0m[Tree] argsB)
    )
        = [*rec(argsA[i], argsB[i]) | i <- [0..size(argsA)]];
    
    [3m[2m// first add required locations to layout nodes[0m
    [3m[2m// TODO: check if indeed repositioning is never needed[0m
    [3m[2m// original = reposition(original, markLit=true, markLayout=true, markSubLayout=true);[0m
    [1mreturn[0m rec(original, formatted);
}

[1mprivate[0m Symbol newlineClass = \char-class([range(10, 10)]) ;

[3m[2m@synopsis{Make sure the new layout still contains all the source code comments of the original layout}[0m
[3m[2m@description{
This algorithm uses the `@category(/[cC]omments/)` tag to detect source code comments inside layout substrings. If the original
layout contains comments, we re-introduce the comments at the expected level of indentation. New comments present in the 
replacement are kept and will overwrite any original comments. 

There are corner cases with respect to the original comments:
* the single line comment that does not end with a newline itself, yet it must always end with a newline after it.
* multiple single line comments after each other

Then there are corner cases with respect to the replacement whitespace:
* the last line of the replacement whitespace is special. This is the indentation to use for all comments.
* but there could be no newlines in the replacement whitespace; and still there is a single line comment to be included.
Now we need to infer an indentation level for what follows the comment from "thin air". 
}[0m
[3m[2m@benefits{
* if comments are kepts and formatted by tools like Tree2Box, then this algorithm does not overwrite these.
* if comments were completely lost, then this algorithm _always_ puts them back (under assumptions of ((layoutDiff)))
* recovered comments are indented according to the indentation discovered in the _formatted_ replacement tree.
}[0m
[3m[2m@pitfalls{
* if comments are not marked with `@category("Comment")` in the original grammar, then this algorithm recovers nothing.
}[0m
[1mprivate[0m [1mstr[0m learnComments(Tree original, Tree replacement) {
    [1mbool[0m mustEndWithNewline(lit("\n")) = [1mtrue[0m;
    [1mbool[0m mustEndWithNewline(conditional(Symbol s, _)) = mustEndWithNewline(s);
    
    [3m[2m// if a comment can not contain newline characters, but everything else, then it must be followed by one:[0m
    [1mbool[0m mustEndWithNewline(\iter(Symbol cc: \char-class(_)))
        = intersection(cc, newlineClass) != newlineClass;
    [1mbool[0m mustEndWithNewline(\iter-star(Symbol cc: \char-class(_)))
        = intersection(cc, newlineClass) != newlineClass;
    [1mdefault[0m [1mbool[0m mustEndWithNewline(_) = [1mfalse[0m;
    
    originalComments
        = [<s, s[[1m-[0m1] == "\n" || mustEndWithNewline(lastSym)>
          | /c: appl(
                    prod(_, [*_, Symbol lastSym], {\tag("category"(/^[Cc]omment$/)), *_}), _
                ) := original, [1mstr[0m s := "<c>"];
    
    [1mif[0m (originalComments == []) {
        [3m[2m// if the original did not contain comments, stick with the replacements[0m
        [1mreturn[0m "<replacement>";
    }
    replacementComments
        = ["<c>"
          | /c: appl(prod(_, _, {\tag("category"(/^[Cc]omment$/)), *_}), _)
            := replacement];
    
    [1mif[0m (replacementComments != []) {
        [3m[2m// if the replacement contains comments, we assume they've been accurately retained by a previous stage (like Tree2Box):[0m
        [1mreturn[0m "<replacement>";
    }
    [3m[2m// At this point, we know that:[0m
    [3m[2m//   (a) comments are not present in the replacement and[0m
    [3m[2m//   (b) they used to be there in the original.[0m
    [3m[2m// So the old comments are going to be copied to the new output.[0m
    [3m[2m// But, we want to indent them using the style of the replacement.[0m
    [3m[2m// The last line of the replacement string typically has the indentation for the construct that follows:[0m
    [3m[2m//   |    // a comment[0m
    [3m[2m//   |    if (true) {[0m
    [3m[2m//    ^^^^[0m
    [3m[2m//      newIndent[0m
    [3m[2m//[0m
    [3m[2m// However, if the replacement string is on a single line, then we don't have the indentation[0m
    [3m[2m// for the string on the next line readily available. In this case we indent the next line[0m
    [3m[2m// to the start column of the replacement layout, as a proxy.[0m
    [1mstr[0m replString = "<replacement>";
    [1mstr[0m newIndent = split("\n", replString)[[1m-[0m1] ? "";
    
    [1mif[0m (/\n/ !:= replString) {
        [3m[2m// no newline in the repl string, so no indentation available for what follows the comment...[0m
        newIndent = "<[1mfor[0m (_ <- [0..replacement@\loc.begin.column]) {> <}>";
    }
    [3m[2m// we always place sequential comments vertically, because we don't know if we are dealing[0m
    [3m[2m// we a single line comment that has to end with newline by follow restriction or by a literal "\n".[0m
    [3m[2m// TODO: a deeper analysis of the comment rule that's in use could also be used to discover this.[0m
    [1mstr[0m trimmedOriginals
        = "<[1mfor[0m (<c, newLine> <- originalComments) {><trim(c)><[1mif[0m (newLine) {>
          '<}><}>";
    
    [3m[2m// we wrap the comment with the formatted whitespace to assure the proper indentation[0m
    [3m[2m// of its first line, and the proper indentation of what comes after this layout node[0m
    [1mreturn[0m
        replString
        + indent(newIndent, trimmedOriginals, indentFirstLine = [1mfalse[0m)
        + newIndent;
}

[1mprivate[0m Symbol delabel(label(_, Symbol t)) = t;
