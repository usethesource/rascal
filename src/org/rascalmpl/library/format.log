    indexes = [i | i <- indexes, counts[i] == max(counts)];
    
    counts = [( 0 | [1mit[0m + 1 | "avoid"() <- tags[i] ) | i <- indexes];
    
    result = {alts[indexes[i]]| i <- index(indexes), counts[i] == min(counts)};
    
    [1mif[0m (result == alternatives) {
        [1mfail[0m directThenCountPreferAvoidFilter;
    }
    [1melse[0m {
        [1mreturn[0m amb(result);
    }
}

[1mlist[0m[[1mlist[0m[[1mvalue[0m]] getTags([1mlist[0m[Tree] ts) = [getTags(t) | t <- ts];

[1mlist[0m[[1mvalue[0m] getTags(Tree t) {
    [1mlist[0m[[1mvalue[0m] result = [];
    todo = [t];
    [1mwhile[0m(todo != []) {
        todoCopy = todo;
        todo = [];
        [1mfor[0m (appl(prod(_, _, tags), args) <- todoCopy) {
            result += [tg | \tag(tg) <- tags];
            todo += args;
        }
    }
    [1mreturn[0m result;
}
