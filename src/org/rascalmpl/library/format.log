    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges([1mmap[0m[[1mstr[0m, [1mvalue[0m] m) = [<"<x>", m[x]> | [1mvalue[0m x <- m];
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges([1mmap[0m[[1mnum[0m, [1mvalue[0m] m) = [<"<x>", m[x]> | [1mvalue[0m x <- m];
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges([1mmap[0m[[1mloc[0m, [1mvalue[0m] m) = [<"<x>", m[x]> | [1mvalue[0m x <- m];
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges([1mmap[0m[[1mnode[0m, [1mvalue[0m] m)
        = [<"key", x>, <"value", m[x]> | [1mvalue[0m x <- m];
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges([1mnode[0m k)
