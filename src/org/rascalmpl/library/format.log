            [1mreturn[0m binFile(name, pcfg, fcfg);
        }
        [1mcatch[0m PathNotFound(_):
            [1mreturn[0m |notFound:///|;
    }
    
    [1mswitch[0m(<source(qualifiedModuleName), target(qualifiedModuleName)>) {
        [1mcase[0m <|notFound:///|, |notFound:///|>:
