[1mpublic[0m [1mset[0m[Symbol] getRestriction(Restriction restriction, [1mbool[0m isLex) {
    println("getting rest: <restriction>");
    [1mswitch[0m(restriction) {
        [1mcase[0m (Restriction) `-/- <Lookaheads _>`:
            [1mreturn[0m {};
        
        [1mcase[0m (Restriction) `LAYOUT? -/- <Lookaheads ls>`:
            [1mreturn[0m
                {conditional(
                     \iter-star(\lex("LAYOUT")), {\not-follow(l)| l <- getLookaheads(ls)}
                 )};
        
        [1mcase[0m (Restriction) `<Sym s1> -/- <Lookaheads ls>`:
            [1mreturn[0m
                {conditional(
                     getSymbol(s1, isLex), {\not-follow(l)| l <- getLookaheads(ls)}
                 )};
        
        [1mcase[0m (Restriction) `<Sym s1> <Sym+ rest> -/- <Lookaheads ls>`:
            [1mreturn[0m
                getRestriction((Restriction) `<Sym s1> -/- <Lookaheads ls>`, isLex)
                + {*getRestriction((Restriction) `<Sym s> -/- <Lookaheads ls>`, isLex)
                  | Sym s <- rest
                  };
        
        [1mdefault[0m: {
            println("WARNING: ignored <restriction>");
            [1mreturn[0m {};
        }
    }
}

