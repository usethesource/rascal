[3m[2m@synopsis{Extract which productions are not to be nested under which other productions, at given 
recursive positions in the parents' defining symbols list.}[0m
[3m[2m@description{
This DoNotNest relation is generated from the grammar using the > priority definitions,
the associativity groups and the ! restriction operator. 

* The > generates a partial order among production rules, which is transitively closed
* The associativity groups fit into this partial order as equivalence classes on the same
  level in the priority ordering. Within these groups left and right recursive rules are
  limited according to the associativity declaration of the given group.
* The DoNotNest relation contains eventually only restrictions in case between two
  related productions an ambiguity can be "proven" to exist between the outermost (left-most
  and right-most) recursive occurences of the defined non-terminal. This is such that
  the disambiguation by priority and associativity remains 'syntax-safe'
* the non-assoc groups and ! are notably not 'syntax-safe', they remove sentences from non-terminals.
}[0m
[1mpublic[0m DoNotNest doNotNest(Grammar g) {
    g = references(g);
    DoNotNest result = {};
    
    [1mfor[0m (s <- g.rules) {
        [3m[2m// note how the analysis is still _per non-terminal_[0m
        [3m[2m// TODO: support relations between mutually recursive non-terminals[0m
        [3m[2m// TODO: support 'deep' priority (for the ML case)[0m
        [3m[2m// TODO: instead of DoNotNest generate data-dependent constraints[0m
        Extracted defined = extract(g.rules[s]);
        
        [3m[2m// select and then close the different relations: left, right, non-assoc and priorities[0m
        [3m[2m// this is to make sure modular specifications (where rules for the same non-terminal are split[0m
        [3m[2m// over several definitions) have the same semantics as a flat, single rule definition.[0m
        [3m[2m// associativity groups are closed, i.e. `a left b && b left c ==> a left c`[0m
        lefts = {<f, c>| <f, \left(), c> <- defined}+;
        rights = {<f, c>| <f, \right(), c> <- defined}+;
        nons = {<f, c>| <f, \non-assoc(), c> <- defined}+;
        prios = {<f, c>| <f, \prio(), c> <- defined};
        
        [3m[2m// `a left b && b > c ==> a > c`, and for right and non-assoc the same[0m
        [3m[2m// `a > b && b left c ==> a > c`, and for right and non-assoc the same[0m
        [3m[2m// TODO: what about open alternative groups specified with |?[0m
        groups = lefts + rights + nons;
        prios += prios [1mo[0m groups + groups [1mo[0m prios;
        
        [3m[2m// the now complete priority relation is transitive[0m
        prios = prios+;
        
        [3m[2m// here we test for some accidental associativity contradictions, remove them and warn about the removal[0m
        [3m[2m// TODO extract checking into separate function[0m
        [1mfor[0m (<f, c> <- (lefts & rights)) {
            [1mif[0m (f == c)
                println(
                    "warning, not syntax-safe: <prod2rascal(f)> is both left and right associative."
                );
            [1melse[0m
                println(
                    "warning, not syntax-safe: <prod2rascal(f)> and <prod2rascal(c)> are both left and right associative to eachother."
                );
        }
        
        [3m[2m// here we test for accidental priority contradictions, remove them and warn about the removal.[0m
        [3m[2m// TODO extract checking into separate function[0m
        [1mfor[0m (<f, c> <- (prios & prios<1,[1m0[0m>)) {
            [1mif[0m (f == c)
                println(
                    "warning, not syntax-safe: <prod2rascal(f)> \> <prod2rascal(c)>, has a priority with itself."
                );
            [1melse[0m
                println(
                    "warning, not syntax-safe: <prod2rascal(f)> {\<,\>} <prod2rascal(c)>, reflexive priority."
                );
        }
        
        [3m[2m// and now we generated the filters, but only if[0m
        [3m[2m// ambiguity can be shown by matching left with right recursive positions[0m
        [3m[2m// TODO: support mutually recursive non-terminals here[0m
        result
            += [3m[2m// left with right recursive[0m
              {<f, 0, c>
               | <f: prod(Symbol ss, [Symbol lr, *_], _), c: prod(Symbol t, [*_, Symbol rr], _)>
                 <-
                 (prios + rights + nons), same(ss, lr), same(t, rr), same(ss, t)
               }
            [3m[2m// right with left recursive[0m
            + {<f, size(pre), c>
              | <f: prod(Symbol ss, [*pre, Symbol rr], _), c: prod(Symbol t, [Symbol lr, *_], _)>
                <-
                (prios + lefts + nons), same(ss, rr), same(t, lr), same(ss, t)
              };
    [3m[2m// and we warn about recursive productions which have been left ambiguous:[0m
    [3m[2m// TODO: this analysis can be done statically in the type-checker[0m
    [3m[2m// allProds  = {p | /p:prod(_,_,_) := g.rules[s]};[0m
    [3m[2m// ambiguous = {<p, q>  | p:prod(Symbol ss, [Symbol lr, *_], _) <- allProds, same(s, lr),[0m
    [3m[2m//                        q:prod(Symbol t, [*_, Symbol rr], _) <- allProds,[0m
    [3m[2m//                         same(t, rr), same(ss, t)};[0m
    [3m[2m// ambiguous += {<p, q> | p:prod(Symbol ss, [*_, Symbol rr], _) <- allProds, same(s, rr),[0m
    [3m[2m//                        q:prod(Symbol t, [Symbol lr,   *_], _) <- allProds,[0m
    [3m[2m//                        same(t, lr), same(ss, t), <q, p> notin ambiguous}[0m
    [3m[2m//           ;[0m
    [3m[2m// ambiguous -= (prios + prios<1,0>); // somehow the pairs are ordered[0m
    [3m[2m// ambiguous -= (groups + groups<1,0>); // somehow the pairs are associative[0m
    [3m[2m// TODO extract checking into separate function[0m
    [3m[2m// for (<p,q> <- ambiguous) {[0m
    [3m[2m//      if (p == q)[0m
    [3m[2m//        jobWarning("warning, ambiguity predicted: <prod2rascal(p)> lacks left or right associativity", |unknown:///|);[0m
    [3m[2m//      else[0m
    [3m[2m//        jobWarning("warning, ambiguity predicted: <prod2rascal(p)> and <prod2rascal(q)> lack left or right associativity or priority (\>)", |unknown:///|);[0m
    [3m[2m// }[0m
    }
    
    [1mreturn[0m result + {*except(p, g)| /Production p <- g, p [1mis[0m prod || p [1mis[0m regular};
}

[1mdefault[0m Extracted extract(Production _) = {};

Extracted extract(choice(Symbol s, [1mset[0m[Production] alts))
    = {*extract(a)| a <- alts};

[3m[2m// note that nested associativity and priority under associativity was removed by an earlier rewrite rule[0m
Extracted extract(
    associativity(Symbol s, Associativity a, [1mset[0m[Production] alts)
)
    = {<x, a, y>| <x, y> <- alts * alts};

Extracted extract(priority(Symbol s, [1mlist[0m[Production] levels))
    = {*extract(high, low)| [*_, Production high, Production low, *_] := levels};

[3m[2m// the follow binary extract rules generate all priority _combinations_ in case of nested groups,[0m
[3m[2m// and also make sure these nested groups can generate the necessary associativity relations[0m
Extracted extract(high: prod(_, _, _), low: prod(_, _, _))
    = {<high, prio(), low >};

Extracted extract(choice(_, [1mset[0m[Production] alts), Production low)
    = {*extract(high, low)| high <- alts};

Extracted extract(Production high, choice(_, [1mset[0m[Production] alts))
    = {*extract(high, low)| low <- alts};

Extracted extract(
    Production a: associativity(_, _, [1mset[0m[Production] alts), Production low
)
    = {*extract(high, low)| high <- alts} + extract(a);

Extracted extract(
    Production high, Production a: associativity(_, _, [1mset[0m[Production] alts)
)
    = {*extract(high, low)| low <- alts} + extract(a);

Extracted extract(
    Production p: priority(Symbol _, [1mlist[0m[Production] alts), Production low
)
    = extract(p) + {*extract(high, low)| high <- alts};

Extracted extract(
    Production high, Production p: priority(Symbol _, [1mlist[0m[Production] alts)
)
    = extract(p) + {*extract(high, low)| low <- alts};

[3m[2m@synopsis{This one-liner searches a given production for "except restrictions". 
For every position in the production that is restricted, and for every restriction it finds 
at this position, it adds a 'do-not-nest' tuple to the result.}[0m
[1mpublic[0m
DoNotNest except(
    Production p: prod(Symbol _, [1mlist[0m[Symbol] lhs, [1mset[0m[Attr] _), Grammar g
