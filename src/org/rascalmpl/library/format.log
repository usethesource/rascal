[1mstr[0m startTag([1mstr[0m n, [1mstr[0m attrs) = "\<<n><attrs>\>";

[1mstr[0m endTag([1mstr[0m n) = "\</<n>\>";

[1mstr[0m startTag([1mstr[0m n, {}) = startTag(n, "");

[1mdefault[0m [1mstr[0m startTag([1mstr[0m n, [1mset[0m[HTML5Attr] attrs)
    = startTag(n, " " + attrsToString(attrs));

[1mstr[0m attrsToString([1mset[0m[HTML5Attr] attrs)
    = intercalate(" ", [attrToString(a) | HTML5Attr a <- attrs]);

[3m[2m// TODO: escaping[0m
[1mstr[0m attrToString(html5attr([1mstr[0m x, [1mvalue[0m v)) = "<x>=\"<v>\"";

[1mstr[0m rawText([1mlist[0m[[1mvalue[0m] xs) = ( "" | [1mit[0m + "<x>" | x <- xs );

[3m[2m// TODO: escaping[0m
[1mstr[0m escapableRawText([1mlist[0m[[1mvalue[0m] xs) = ( "" | [1mit[0m + "<x>" | x <- xs );

[1mstr[0m kidsToString([1mlist[0m[[1mvalue[0m] kids) = ( "" | [1mit[0m + kidToString(k) | k <- kids );

[1mstr[0m kidToString(HTML5Node elt) = toString(elt);
[1mstr[0m kidToString(HTML5Attr x) = "";

[1mdefault[0m [1mstr[0m kidToString([1mvalue[0m x) = "<x>";

[1mstr[0m nodeToString([1mstr[0m n, [1mset[0m[HTML5Attr] attrs, [1mlist[0m[[1mvalue[0m] kids) {
    [1mstr[0m s = "";
    [1mif[0m (isVoid(n)) {
        [3m[2m// ignore kids...[0m
        s += startTag(n, attrs);
    }
    [1melse[0m [1mif[0m (isRawText(n)) {
        s += startTag(n, attrs);
        s += rawText(kids);
        s += endTag(n);
    }
    [1melse[0m [1mif[0m (isEscapableRawText(n)) {
        s += startTag(n, attrs);
        s += escapableRawText(kids);
        s += endTag(n);
    }
    [1melse[0m [1mif[0m (isBlockLevel(n)) {
        s
            += "<startTag(n, attrs)>
               '  <[1mfor[0m (k <- kids) {><kidToString(k)>
               '  <}><endTag(n)>";
    }
    [1melse[0m {
        s += startTag(n, attrs);
        s += kidsToString(kids);
        s += endTag(n);
    }
    [1mreturn[0m s;
}

[1mprivate[0m HTML5Node example
    = html(
          head(title("something")),
          body(ul(li("bla"), li("foo", 3, img(ahref("someref")))))
      ) ;

[3m[2m@synopsis{pretty print HTML5Node DOM to a string}[0m
[1mstr[0m toString(HTML5Node x) {
    attrs = {k| HTML5Attr k <- x.kids};
    kids = [k | [1mvalue[0m k <- x.kids, !(HTML5Attr _ := k)];
    [1mreturn[0m nodeToString(x.name, attrs, kids);
}
