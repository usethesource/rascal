        [1mcase[0m \empty():
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \cilit(_):
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \char-class(_):
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \layouts(_):
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \keywords(_):
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \start(_):
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \parameterized-sort(_, [\parameter(_, _), *_]):
            [1mreturn[0m [1mfalse[0m;
        [1mcase[0m \parameterized-lex(_, [\parameter(_, _), *_]):
            [1mreturn[0m [1mfalse[0m;
