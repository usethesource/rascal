[1mmodule[0m lang::rascal::tests::concrete::PostParseFilter

[3m[2m// copied from issue report #1210[0m
[1mimport[0m Exception;
[1mimport[0m ParseTree;

[1msyntax[0m X
    = a: A
    | b: B
    ;
[1msyntax[0m A = "X";
[1msyntax[0m B = "X";

[3m[2m// Match a concrete pattern to have an X as return value.[0m
X amb({f: (X)`<A _>`, *[1mvalue[0m _}) = f;

[1mtest[0m [1mbool[0m t1() {
    [1mtry[0m {
        [3m[2m// TODO: if allowAmbiguity=false one might expect this test to succeed as well,[0m
        [3m[2m// but it doesn't because the rewrite rule is never executed before the exception[0m
        [3m[2m// has been thrown already. See the discussion with issue #1210[0m
        Tree t = parse(#X, "X", allowAmbiguity = [1mtrue[0m);
        [1mreturn[0m [1mtrue[0m;
    }
    [1mcatch[0m Ambiguity([1mloc[0m _, [1mstr[0m _, [1mstr[0m _): {
        Tree t = parse(#X, "X", allowAmbiguity = [1mtrue[0m);
        [1massert[0m /amb(_) !:= t : "Tree still contains an ambiguity node.";
        [1mreturn[0m [1mfalse[0m;
    }
}
