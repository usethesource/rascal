[3m[2m@synopsis{Syntax definition for Unified Diff format (see <http://en.wikipedia.org/wiki/Diff_utility#Unified_format>)}[0m
[3m[2m@contributor{Tijs van der Storm - storm@cwi.nl (CWI)}[0m
[1mmodule[0m lang::diff::unified::UnifiedDiff

[1mstart[0m [1msyntax[0m DiffFile = Diff;

[1msyntax[0m Diff = Header old Header new Chunk* chunks;

[1msyntax[0m Chunk = ChunkStart Line+;

[1msyntax[0m ChunkStart = ^"@@ -" Range " +" Range " @@" Content;

[1msyntax[0m Header = ^Indicator " " FileName DateTime? "\n";

[1msyntax[0m DateTime = "\t" Date date " " Time time " " TimeZone timeZone;

[1mlexical[0m FileName = ![\t\n]*;

[1msyntax[0m Indicator
