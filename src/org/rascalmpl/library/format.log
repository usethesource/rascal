[1mset[0m[Production] expand([1mset[0m[Production] prods) {
    [3m[2m// First we collect all the parametrized definitions[0m
    defs
        = {p
          | p <- prods, Symbol s := delabel(p.def), s [1mis[0m \parameterized-sort || s [1mis[0m \parameterized-lex
          };
    result = prods [1m-[0m defs;
    
    [3m[2m// Then we collect all the uses of parameterized sorts in the other productions[0m
    uses
        = {s| /Symbol s <- result, s [1mis[0m \parameterized-sort || s [1mis[0m \parameterized-lex};
    
    [3m[2m// Now we copy each definition for each use and rename the parameters[0m
    [3m[2m// Note that we assume normalization will remove the duplicates we introduce by instantiating the a definition twice[0m
    [3m[2m// with the same actual parameters.[0m
    instantiated = {};
    [1mwhile[0m(uses != {}) {
        instances = {};
        [1mfor[0m (u <- uses, def <- defs, def.def.name == u.name) {
            name = u.name;
            actuals = u.parameters;
            formals = def.def.parameters;
            instantiated += {u};
            substs = (formals[i]: actuals[i]| [1mint[0m i <- index(actuals) & index(formals));
            instances
                = {*instances, [1mvisit[0m(def) {
                                   [1mcase[0m Symbol par: \parameter(_, _) => substs[par] ? par
                               }};
        }
        
        [3m[2m// now, we may have created more uses of parameterized symbols, by instantiating nested parameterized symbols[0m
        uses
            = {s
              | /Symbol s <- instances, s [1mis[0m \parameterized-sort || s [1mis[0m \parameterized-lex, s [1mnotin[0m instantiated
              };
        result += instances;
    }
    
    [1mreturn[0m result;
}
