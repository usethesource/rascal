Box toBox(
    s: (Statement) `<Label label> if (<{Expression ","}+ cs>) [1m
[0m                      '  <Statement sts>`
)
    = (Statement) `if (<Expression cond>) println(<Expression log>);` := s
          ? H1(
                H0([H1(L("if"), L("(")), I(HOV(toBox(cs))), L(")")]),
                H0(L("println"), L("("), toExpBox(log), L(")"), L(";"))
            )
          : (Statement) `if (<Expression cond>) { println(<Expression log>); }` :=
            s
                ? H1(
                      H0(H0(H1(L("if"), L("(")), I(HOV(toBox(cs))), L(")"))),
                      L("{"),
                      H0(L("println"), L("("), I(HOV(toExpBox(log))), L(")"), L(";")),
                      L("}")
                  )
                : V(
                      HV(
                          H0(toBox(label), H(L("if"), L("(")), toBox(cs), L(")")), blockOpen(sts)
                      ),
                      indentedBlock(sts),
                      blockClose(sts)
                  );

