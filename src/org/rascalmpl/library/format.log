[3m[2m@synopsis{This function evaluates lookahead sets to obtain an optimal production selection automaton
  As a side-effect it also needs to replace priority ordering and associativity by the simple choice operator!}[0m
[1mpublic[0m Grammar compileLookaheads(Grammar G) {
    [3m[2m// first we remove first and assoc groups for simplicity's sake[0m
    G = [1mvisit[0m(G) {
            [1mcase[0m lookahead(rhs, {}, _) => choice(rhs, {})
            [1mcase[0m priority(rhs, order) => choice(rhs, {p| p <- order})
            [1mcase[0m associativity(rhs, _, alts) => choice(rhs, alts)
