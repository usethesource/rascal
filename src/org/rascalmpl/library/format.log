Content showValue([1mvalue[0m v) = content(md5Hash(v), valueServer(v));

Response(Request) valueServer([1mvalue[0m v) {
    Response reply(get(/^\/editor/,parameters = pms)) {
        [1mif[0m (pms["src"]?) {
            edit(readTextValueString(#[1mloc[0m, pms["src"]));
            [1mreturn[0m response(writeHTMLString(text("done")));
        }
        [1mreturn[0m response(writeHTMLString(text("could not edit <pms>")));
    }
    
    [1mdefault[0m Response reply(get(_)) {
        [1mreturn[0m response(writeHTMLString(toHTML(v)));
    }
    
    [1mreturn[0m reply;
}

HTMLElement toHTML([1mnum[0m i) = text("<i>");
HTMLElement toHTML([1mstr[0m s) = pre([p([text(s)])]);
HTMLElement toHTML([1mloc[0m l)
    = a([ text("<l>") ], href = "#", onclick = "fetch(\"/editor?src=<l>\")" );

HTMLElement toHTML([1mlist[0m[[1mvalue[0m] l)
    = div([
          b([text("<[1mtype[0m(typeOf(l), ())> (<sampled(l, 100)>)")]),
          ul([li([toHTML(e)]) | e <- sample(l, 100)])
      ]);

