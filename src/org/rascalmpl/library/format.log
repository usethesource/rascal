[1mpublic[0m [1mstr[0m attr2mod(Attr a) {
    [1mswitch[0m(a) {
        [1mcase[0m \bracket():
            [1mreturn[0m "bracket";
        [1mcase[0m \tag([1mstr[0m x([1mstr[0m y)):
            [1mreturn[0m "@<x>=\"<escape(y)>\"";
        [1mcase[0m \tag([1mstr[0m x()):
            [1mreturn[0m "@<x>";
        [1mcase[0m \assoc(Associativity as):
            [1mreturn[0m associativity(as);
        [1mdefault[0m:
            [1mreturn[0m "@Unsupported(\"<escape("<a>")>\")";
    }
}

[1mpublic[0m [1mstr[0m symbol2rascal(Symbol sym) {
    [1mswitch[0m(sym) {
        [1mcase[0m label([1mstr[0m l, x):
            [1mreturn[0m "<symbol2rascal(x)> <l>";
        [1mcase[0m sort(x):
            [1mreturn[0m x;
        [1mcase[0m lit(x):
            [1mreturn[0m "\"<escape(x)>\"";
        [1mcase[0m cilit(x):
            [1mreturn[0m "\'<escape(x)>\'";
        [1mcase[0m \lex(x):
            [1mreturn[0m x;
        [1mcase[0m \keywords(x):
            [1mreturn[0m x;
        [1mcase[0m \parameterized-sort([1mstr[0m name, [1mlist[0m[Symbol] parameters):
            [1mreturn[0m "<name>[<params2rascal(parameters)>]";
        [1mcase[0m \parameterized-lex([1mstr[0m name, [1mlist[0m[Symbol] parameters):
            [1mreturn[0m "<name>[<params2rascal(parameters)>]";
        [1mcase[0m parameter([1mstr[0m t, _):
            [1mreturn[0m "&<t>";
        [1mcase[0m \char-class(x):
            [1mif[0m (\char-class(y) := complement(sym)) {
                [1mstr[0m norm = cc2rascal(x);
                [1mstr[0m comp = cc2rascal(y);
                [1mreturn[0m size(norm) > size(comp) ? "!<comp>" : norm;
            }
            [1melse[0m
                [1mthrow[0m "weird result of character class complement";
        [1mcase[0m \seq(syms):
            [1mreturn[0m "( <[1mfor[0m (s <- syms) {> <symbol2rascal(s)> <}> )";
        [1mcase[0m opt(x):
            [1mreturn[0m "<symbol2rascal(x)>?";
        [1mcase[0m iter(x):
            [1mreturn[0m "<symbol2rascal(x)>+";
        [1mcase[0m \iter-star(x):
            [1mreturn[0m "<symbol2rascal(x)>*";
        [1mcase[0m \iter-seps(x, seps):
            [1mreturn[0m iterseps2rascal(x, seps, "+");
        [1mcase[0m \iter-star-seps(x, seps):
            [1mreturn[0m iterseps2rascal(x, seps, "*");
        [1mcase[0m alt([1mset[0m[Symbol] alts): {
            <f, as> = takeOneFrom(alts);
            [1mreturn[0m "(" + ( symbol2rascal(f) | "<[1mit[0m> | <symbol2rascal(a)>" | a <- as ) + ")";
        }
        [1mcase[0m seq([1mlist[0m[Symbol] ss): {
            <f, as> = takeOneFrom(ss);
            [1mreturn[0m "(" + ( symbol2rascal(f) | "<[1mit[0m> <symbol2rascal(a)>" | a <- as ) + ")";
        }
        [1mcase[0m \layouts([1mstr[0m _):
            [1mreturn[0m "";
        [1mcase[0m \start(x):
            [1mreturn[0m symbol2rascal(x);
        
        [3m[2m// Following are type-incorrect, PK.[0m
        [3m[2m//case intersection(lhs, rhs):[0m
        [3m[2m//    return "<symbol2rascal(lhs)> && <symbol2rascal(rhs)>";[0m
        [3m[2m//case union(lhs, rhs):[0m
        [3m[2m// 	return "<symbol2rascal(lhs)> || <symbol2rascal(rhs)>";[0m
        [3m[2m//case difference(Class lhs, Class rhs):[0m
        [3m[2m// 	return "<symbol2rascal(lhs)> -  <symbol2rascal(rhs)>";[0m
        [3m[2m//case complement(Class lhs):[0m
        [3m[2m// 	return "!<symbol2rascal(lhs)>";[0m
        [1mcase[0m conditional(Symbol s, {Condition c, Condition d, *Condition r}):
            [1mreturn[0m symbol2rascal(conditional(conditional(s, {c}), {d, *r}));
        [1mcase[0m conditional(s, {delete(t)}):
            [1mreturn[0m "<symbol2rascal(s)> \\ <symbol2rascal(t)>";
        [1mcase[0m conditional(s, {follow(t)}):
            [1mreturn[0m "<symbol2rascal(s)> \>\> <symbol2rascal(t)>";
        [1mcase[0m conditional(s, {\not-follow(t)}):
            [1mreturn[0m "<symbol2rascal(s)> !\>\> <symbol2rascal(t)>";
        [1mcase[0m conditional(s, {precede(t)}):
            [1mreturn[0m "<symbol2rascal(t)> \<\< <symbol2rascal(s)> ";
        [1mcase[0m conditional(s, {\not-precede(t)}):
            [1mreturn[0m "<symbol2rascal(t)> !\<\< <symbol2rascal(s)> ";
        [1mcase[0m conditional(s, {\at-column([1mint[0m i)}):
            [1mreturn[0m "<symbol2rascal(s)>@<i>";
        [1mcase[0m conditional(s, {\begin-of-line()}):
            [1mreturn[0m "^<symbol2rascal(s)>";
        [1mcase[0m conditional(s, {\end-of-line()}):
            [1mreturn[0m "<symbol2rascal(s)>$";
        [1mcase[0m conditional(s, {\except([1mstr[0m x)}):
            [1mreturn[0m "<symbol2rascal(s)>!<x>";
        [1mcase[0m conditional(s, {}): {
            println("WARNING: empty conditional <sym>");
            [1mreturn[0m symbol2rascal(s);
        }
        [1mcase[0m empty():
            [1mreturn[0m "()";
    }
    
    [1mthrow[0m "symbol2rascal: missing case <sym>";
}

[1mpublic[0m [1mstr[0m iterseps2rascal(Symbol sym, [1mlist[0m[Symbol] seps, [1mstr[0m iter) {
    separators = "<[1mfor[0m (sp <- seps) {><symbol2rascal(sp)><}>";
    [1mif[0m (separators != "")
        [1mreturn[0m "{<symbol2rascal(sym)> <separators>}<iter>";
    [1melse[0m
        [1mreturn[0m "<symbol2rascal(sym)><separators><iter>";
}

[1mpublic[0m [1mstr[0m params2rascal([1mlist[0m[Symbol] params) {
    len = size(params);
    [1mif[0m (len == 0)
        [1mreturn[0m "";
    [1mif[0m (len == 1)
        [1mreturn[0m symbol2rascal(params[0]);
    sep = "";
    res = "";
    [1mfor[0m (Symbol p <- params) {
        res += sep + symbol2rascal(p);
        sep = ", ";
    }
    [1mreturn[0m res;
}

[1mpublic[0m [1mstr[0m cc2rascal([1mlist[0m[CharRange] ranges) {
    [1mif[0m (ranges == [])
        [1mreturn[0m "[]";
    [1mreturn[0m
        "[<range2rascal(head(ranges))><[1mfor[0m (r <- tail(ranges)) {> <range2rascal(r)><}>]";
}

[1mpublic[0m [1mstr[0m range2rascal(CharRange r) {
    [1mswitch[0m(r) {
        [1mcase[0m range(c, c):
            [1mreturn[0m makeCharClassChar(c);
        [1mcase[0m range(c, d):
            [1mreturn[0m "<makeCharClassChar(c)>-<makeCharClassChar(d)>";
        
        [3m[2m//TODO:[0m
        [3m[2m//case \empty-range():[0m
        [3m[2m//                  return "";[0m
        [1mdefault[0m:
            [1mthrow[0m "range2rascal: missing case <r>";
    }
}
