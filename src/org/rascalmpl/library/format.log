[3m[2m// visit implementations may group patterns by outermost function[0m
[3m[2m// symbol. In issue #1719 we saw that this optimization introduced[0m
[3m[2m// a bug that would leak pattern variables between cases of the same[0m
[3m[2m// outermost function symbol when the pattern failed halfway through.[0m
[3m[2m// these tests would trigger that bug.[0m
[1mdata[0m Bool
    = \true()
    | \false()
    | \and(Bool lhs, Bool rhs)
    | \or(Bool lhs, Bool rhs)
    | \not(Bool arg)
    | \cond(Bool cond, Bool lhs, Bool rhs)
    | \null()
    ;

[1mpublic[0m [1mlist[0m[Bool] examples
    = [
          and(and(and(\true(), and(\false(), \true())), \true()), \false()),
          and(
              \true(), cond(and(\false(), \true()), or(\false(), \true()), \false())
          ),
          or(\false(), \true()),
          and(\true(), cond(and(\true(), \true()), or(\false(), \true()), \false())),
          and(
              \true(),
              cond(and(\false(), \true()), null(), cond(\true(), null(), null()))
          )
      ] ;

Bool reduce(Bool b)
    = [1minnermost[0m [1mvisit[0m(b) {
          [1mcase[0m \and(\true(), X) => X
          [1mcase[0m \and(X: \false(), _) => X
          [1mcase[0m \and(Bool X, \true()) => X
          [1mcase[0m \and(_, X: \false()) => X
          [1mcase[0m \or(X: \true(), _) => X
          [1mcase[0m \or(_, X: \true()) => X
          [1mcase[0m \or(\false(), X) => X
          [1mcase[0m \or(Bool X, \false()) => X
          [1mcase[0m \cond(\true(), X, _) => X
          [1mcase[0m \cond(\false(), _, X) => X
          [1mcase[0m 1 => 1
      };

[1mbool[0m normal(\false()) = [1mtrue[0m;
[1mbool[0m normal(\true()) = [1mtrue[0m;
[1mbool[0m normal(null()) = [1mtrue[0m;
[1mdefault[0m [1mbool[0m normal(Bool _) = [1mfalse[0m;

[1mtest[0m [1mbool[0m allExamplesNormalAfterVisit()
    = [1mall[0m(x <- examples, normal(reduce(x)));
