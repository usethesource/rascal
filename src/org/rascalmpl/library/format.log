    avoids = {t| t: appl(prod(_, _, {\tag("avoid"()), *_}), _) <- alternatives};
    
    [1mif[0m (size(alternatives) == (size(avoids) + 1)) {
        [1mreturn[0m ParseTree::amb(alternatives [1m-[0m avoids);
