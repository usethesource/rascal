    = assureRange([0..10], 100, 110) == [100..110];
[1mtest[0m [1mbool[0m assureRangeListTestNeg()
    = assureRange([0..[1m-[0m10], 100, 110) == [100, *[109, 108, 107, 106, 105, 104, 103, 102, 101]];
