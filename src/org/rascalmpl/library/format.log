[1mmodule[0m util::PriorityQueue

[3m[2m/*
 * Priority queues maintain (value, priority) pairs in sorted order.
 * They are implemented using a binomial heap, see http://en.wikipedia.org/wiki/Binomial_heap
 * The following operations are provided:
 * - PriorityQueue priorityQueue():
 *		create an empty queue.
 * - PriorityeQueue priorityQueue(int priority, int val):
 *		create queue with one pair.
 * - bool isEmpty(PriorityQueue Q):
 *		test for empty queue.
 * - PriorityQueue insertElement(PriorityQueue Q, int priority, int val):
 *		insert pair in queue.
 * - int findMinimum(PriorityQueue Q):
 *		find the minimum priority.
 * - tuple[int, int, PriorityQueue] extractMinimum(PriorityQueue Q):
 *		find the pair with minimum priority and delete it.
 */[0m[3m[2m/*
  * TODO: the value in each pair is now an int but should become &T.
 */[0m[1mimport[0m util::Math;
[1mimport[0m List;

[3m[2m// Binomial Trees[0m
[1mprivate[0m [1mdata[0m BinomialTree
    = binomialTree([1mint[0m priority, [3m[2m// priority of this tree[0m
                                [1mint[0m val, [3m[2m// payload[0m
                                         [1mint[0m degree, [3m[2m// degree of tree[0m
                                                     [1mlist[0m[BinomialTree] children[3m[2m// subtrees[0m
                                                                                 );

[1mprivate[0m BinomialTree addSubTree(BinomialTree p, BinomialTree q) {
    [1mreturn[0m binomialTree(p.priority, p.val, p.degree + 1, p.children + [q]);
}

[1mprivate[0m BinomialTree mergeTree(BinomialTree p, BinomialTree q) {
    [1mreturn[0m (p.priority <= q.priority) ? addSubTree(p, q) : addSubTree(q, p);
}

[1mprivate[0m [1mstr[0m toString(BinomialTree T) {
    [1mstr[0m res = "[" + toString(T.priority) + "/" + toString(T.val);
    [1mif[0m (!isEmpty(T.children))
        res = res + ":";
    [1mfor[0m (BinomialTree child <- T.children) {
        res = res + " " + toString(child);
    }
    [1mreturn[0m res + "]";
}

[3m[2m// Priority Queues implemented as Binomial Heap[0m
[1mdata[0m PriorityQueue = priorityQueue([1mlist[0m[BinomialTree] trees, [3m[2m// trees in the heap[0m
                                                            [1mint[0m minIndex[3m[2m// index of minimal tree[0m
                                                                         );

[1mpublic[0m PriorityQueue mkPriorityQueue() {
    [1mreturn[0m priorityQueue([], [1m-[0m1);
}

[1mpublic[0m PriorityQueue mkPriorityQueue([1mint[0m priority, [1mint[0m val) {
    [1mreturn[0m priorityQueue([binomialTree (
                              priority,
                              val,
                              0,
                              []
                          )], 0);
}

[1mpublic[0m [1mbool[0m isEmpty(PriorityQueue Q) {
    [1mreturn[0m size(Q.trees) == 0;
}

[1mpublic[0m PriorityQueue insertElement(PriorityQueue Q, [1mint[0m priority, [1mint[0m val) {
    [1mreturn[0m mergeQueue(Q, mkPriorityQueue(priority, val));
}

[1mpublic[0m [1mint[0m findMinimum(PriorityQueue Q) {
    [1mreturn[0m Q.trees[Q.minIndex].priority;
[3m[2m// throw exception for empty queue.[0m
}

[1mpublic[0m [1mtuple[0m[[1mint[0m, [1mint[0m, PriorityQueue] extractMinimum(PriorityQueue Q) {
    minTree = Q.trees[Q.minIndex];
    
    Q.trees = delete(Q.trees, Q.minIndex);
    
    [3m[2m// Determine the new minimal tree[0m
    [1mint[0m minIndex = [1m-[0m1;
    [1mint[0m minPrio = 10000;
    [1mfor[0m ([1mint[0m i <- index(Q.trees)) {
        [1mif[0m (Q.trees[i].priority < minPrio) {
            minPrio = Q.trees[i].priority;
            minIndex = i;
        }
    }
    Q.minIndex = minIndex;
    
    [1mreturn[0m
        <minTree.priority,
         minTree.val,
         mergeQueue(Q, priorityQueue(minTree.children, 0))>;
}

[1mpublic[0m [1mstr[0m toString(PriorityQueue Q) {
    [1mstr[0m res = "(";
    [1mfor[0m ([1mint[0m i <- index(Q.trees)) {
        res = res + "\n" + toString(i) + ":" + toString(Q.trees[i]);
    }
    [1mreturn[0m res + "\n)";
}

[1mprivate[0m [1mint[0m minPrio = 100000 ;
[1mprivate[0m [1mint[0m minIndexFromEnd = [1m-[0m1 ;

[1mprivate[0m [1mlist[0m[BinomialTree] add([1mlist[0m[BinomialTree] heap, BinomialTree t) {
    [1mif[0m (isEmpty(heap)) {
        [1mif[0m (t.priority == minPrio)
            minIndexFromEnd = 0;
        [1mreturn[0m [t];
    }
    [1melse[0m [1mif[0m (head(heap).degree == t.degree) {
        m = mergeTree(head(heap), t);
        [1mif[0m (m.priority == minPrio) {
            minIndexFromEnd = size(heap);
        }
        [1mreturn[0m [m, *tail(heap)];
    }
    [1melse[0m {
        [1mif[0m (t.priority == minPrio)
            minIndexFromEnd = size(heap);
        [1mreturn[0m [t, *heap];
    }
}

[1mprivate[0m PriorityQueue mergeQueue(PriorityQueue p, PriorityQueue q) {
    pTrees = p.trees;
    [1mif[0m (isEmpty(pTrees))
        [1mreturn[0m q;
    qTrees = q.trees;
    [1mif[0m (isEmpty(qTrees))
        [1mreturn[0m p;
    [1mint[0m fromEnd = [1m-[0m1;
    
    [3m[2m// index of smallest tree from end[0m
    [1mif[0m (pTrees[p.minIndex].priority <= qTrees[q.minIndex].priority) {
        minPrio = pTrees[p.minIndex].priority;
        fromEnd = size(pTrees) [1m-[0m p.minIndex;
    }
    [1melse[0m {
        minPrio = qTrees[q.minIndex].priority;
        fromEnd = size(qTrees) [1m-[0m q.minIndex;
    }
    minIndexFromEnd = [1m-[0m1;
    
    [1mlist[0m[BinomialTree] heapTrees = [];
    
    [1mwhile[0m(!isEmpty(pTrees) && !isEmpty(qTrees)) {
        hp = head(pTrees);
        hq = head(qTrees);
        [1mif[0m (hp.degree < hq.degree) {
            heapTrees = add(heapTrees, hp);
            pTrees = tail(pTrees);
        }
        [1melse[0m [1mif[0m (hp.degree == hq.degree) {
            heapTrees = add(heapTrees, mergeTree(hp, hq));
            pTrees = tail(pTrees);
            qTrees = tail(qTrees);
        }
        [1melse[0m {
            heapTrees = add(heapTrees, hq);
            qTrees = tail(qTrees);
        }
    }
    rest = isEmpty(pTrees) ? qTrees : pTrees;
    heapTrees = rest + heapTrees;
    
    [1mint[0m min = [1m-[0m1;
    
    [1mif[0m (minIndexFromEnd == [1m-[0m1) {
        [3m[2m// Minimal element appears in rest[0m
        min = fromEnd;
    }
    [1melse[0m {
        [3m[2m// Minimal element already seen.[0m
        min = size(heapTrees) [1m-[0m minIndexFromEnd [1m-[0m 1;
    }
    
    [3m[2m//println("heapTrees=<heapTrees>");[0m
    [3m[2m//println("minIndexFromEnd=<minIndexFromEnd>, minPrio=<minPrio>, min=<min>");[0m
    [1mreturn[0m priorityQueue(heapTrees, min);
}
