[3m[2m@synopsis{Complement of a list relation.}[0m
[3m[2m@description{
Given a list relation `R` a new relation `U` can be constructed that contains
all possible tuples with element values that occur at corresponding tuple positions in `R`.
The function `complement` returns the complement of `R` relative to `U`, in other words: `U - R`.
}[0m
[3m[2m@examples{
```rascal-shell
import ListRelation;
```

Declare `R` and compute corresponding `U`:

```rascal-shell,continue
R = [<1,10>, <2, 20>, <3, 30>];
U = domain(R) * range(R);
```

Here is the complement of `R` computed in two ways:
```rascal-shell,continue
U - R;
complement([<1,10>, <2, 20>, <3, 30>]);
```
}[0m
[1mpublic[0m
[1mlrel[0m[&T0, &T1] complement([1mlrel[0m[&T0, &T1] R)
    = size(R) < 2 ? [] : dup([<V0, V1> | &T0 V0 <- R<[1m0[0m>, &T1 V1 <- R<1>, <V0, V1> [1mnotin[0m R]);

[3m[2m// Was:  (domain(R) * range(R)) - R;[0m
[1mpublic[0m
[1mlrel[0m[&T0, &T1, &T2] complement([1mlrel[0m[&T0, &T1, &T2] R)
    = dup(
          [<V0, V1, V2> | &T0 V0 <- R<[1m0[0m>, &T1 V1 <- R<1>, &T2 V2 <- R<2>, <V0, V1, V2> [1mnotin[0m R]
      );

[1mpublic[0m
[1mlrel[0m[&T0, &T1, &T2, &T3] complement([1mlrel[0m[&T0, &T1, &T2, &T3] R)
    = dup(
          [<V0, V1, V2, V3>
          | &T0 V0 <- R<[1m0[0m>, &T1 V1 <- R<1>, &T2 V2 <- R<2>, &T3 V3 <- R<3>, <V0, V1, V2, V3> [1mnotin[0m R]
      );

[1mpublic[0m
[1mlrel[0m[&T0, &T1, &T2, &T3, &T4] complement([1mlrel[0m[&T0, &T1, &T2, &T3, &T4] R)
    = dup(
          [<V0, V1, V2, V3, V4>
          | &T0 V0 <- R<[1m0[0m>, &T1 V1 <- R<1>, &T2 V2 <- R<2>, &T3 V3 <- R<3>, &T4 V4 <- R<4>, <V0, V1, V2, V3, V4> [1mnotin[0m R]
      );

