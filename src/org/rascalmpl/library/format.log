### |project://rascal/src/org/rascalmpl/library/lang/pico/HiFiDemo.rsc|
[3m[2m@synopsis{Demonstrates HiFi source-to-source transformations through concrete syntax rewrites and text edits.}[0m
[1mmodule[0m lang::pico::HiFiDemo

[1mimport[0m lang::pico::\syntax::Main;
[1mimport[0m IO;
[1mimport[0m ParseTree;
[1mimport[0m analysis::diff::edits::HiFiTreeDiff;
[1mimport[0m analysis::diff::edits::ExecuteTextEdits;

[3m[2m@synopsis{Blindly swaps the branches of all the conditionals in a program}[0m
[3m[2m@description{
This rule is syntactically correct and has a clear semantics. The 
layout of the resulting if-then-else-fi statement is also clear.
}[0m
[1mstart[0m[Program] flipConditionals([1mstart[0m[Program] program)
    = [1mvisit[0m(program) {
          [1mcase[0m (Statement) `if <Expression e> then [1m
[0m                     '  <{Statement ";"}* ifBranch>[1m
[0m                     'else [1m
[0m                     '  <{Statement ";"}* elseBranch>[1m
[0m                     'fi`
              => (Statement) `if <Expression e> then [1m
[0m                     '  <{Statement ";"}* elseBranch>[1m
[0m                     'else [1m
[0m                     '  <{Statement ";"}* ifBranch>[1m
[0m                     'fi`
      };

[1mvoid[0m main() {
    t
        = parse(
              #[1mstart[0m[Program],
              |project://rascal/src/org/rascalmpl/library/lang/pico/examples/flip.pico|
          );
    println("The original: 
            '<t>");
    
    u = flipConditionals(t);
    println("Branches swapped, comments and indentation lost:
            '<u>");
    
    edits = treeDiff(t, u);
    println("Smaller text edits:");
    iprintln(edits);
    
    newContent = executeTextEdits("<t>", edits);
    println("Better output after executeTextEdits:
            '<newContent>");
    
    newU = parse(#[1mstart[0m[Program], newContent);
    
    [1massert[0m u := newU : "the rewritten tree matches the newly parsed";
}
### |project://rascal/src/org/rascalmpl/library/lang/pico/format/Formatting.rsc|
[3m[2m@synopsis{Demonstrates ((Tree2Box)), ((Box2Text)) and ((HiFiLayoutDiff)) for constructing a declarative and HiFi Pico formatting pipeline}[0m
[3m[2m@description{
Using four generic or generated, "language parametric", building blocks we construct a Pico formatting pipeline:

* ((ParseTree)) is used to _generate_ a parser for Pico.   
* ((Tree2Box)) provides the extensible/overridable and declarative ((toBox)) function which maps language constructs to Box expressions. 
The ((toBox)) function combines generic language-parametric rules, as well as bespoke language specific rules..
* ((Box2Text)) is a _generic_ reusable algorithm for two-dimensional string layout.
* Finally, ((HiFiLayoutDiff)) _generically_ extracts ((TextEdit))s from two trees which are equal modulo whitespace and comments.
}[0m
[3m[2m@benefits{
* The formatting is style is programmed _declaratively_ by mapping language patterns to Box expressions.
* The pipeline never loses source code comments, and this requires no attention from the language engineer.
}[0m
[3m[2m@pitfalls{
* ((Box2Text)) must be _extended_ for the open recursive calls of ((toBox)) to reach the extensions in the current module. 
If you import ((Box2Text)) the extended ((toBox)) rules will only be found if they describe top-level tree nodes.
}[0m
[1mmodule[0m lang::pico::format::Formatting

[1mextend[0m lang::box::util::Tree2Box;

[1mimport[0m ParseTree;
[1mimport[0m analysis::diff::edits::ExecuteTextEdits;
[1mimport[0m analysis::diff::edits::HiFiLayoutDiff;
[1mimport[0m lang::box::\syntax::Box;
[1mimport[0m lang::box::util::Box2Text;
[1mimport[0m lang::pico::\syntax::Main;

[3m[2m@synopsis{In-place formatting of an entire Pico file}[0m
[1mvoid[0m formatPicoFile([1mloc[0m file) {
    edits = formatPicoTree(parse(#[1mstart[0m[Program], file));
    executeFileSystemChanges([changed(file, edits)]);
}

[3m[2m@synopsis{Format a string that contains an entire Pico program}[0m
[1mstr[0m formatPicoString([1mstr[0m file) {
    [1mstart[0m[Program] tree = parse(#[1mstart[0m[Program], file, |unknown:///|);
    [1mreturn[0m executeTextEdits(file, formatPicoTree(tree));
}

[3m[2m@synopsis{Pico Format function for reuse in file, str or IDE-based formatting contexts}[0m
[1mlist[0m[TextEdit] formatPicoTree([1mstart[0m[Program] file) {
    formatted = format(toBox(file));
    [1mreturn[0m layoutDiff(file, parse(#[1mstart[0m[Program], formatted, file@\loc.top));
}

[3m[2m@synopsis{Format while}[0m
Box toBox(
    (Statement) `while <Expression e> do <{Statement ";"}* block> od`,
    FO opts = fo()
)
    = V(
          H(L("while"), HV(toBox(e, opts = opts)), L("do")),
          I(toClusterBox(block, opts = opts)),
          L("od")
      );

[3m[2m@synopsis{Format if-then-else }[0m
Box toBox(
    (Statement) `if <Expression e> then <{Statement ";"}* thenPart> else <{Statement ";"}* elsePart> fi`,
    FO opts = fo()
)
    = V(
          H(L("if"), HV(toBox(e, opts = opts)), L("then")),
          I(toClusterBox(thenPart, opts = opts)),
          L("else"),
          I(toClusterBox(elsePart, opts = opts)),
          L("fi")
      );
