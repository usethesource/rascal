            | assignDiv: Expression lhs "/=" Expression rhs
            | assignRem: Expression lhs "%=" Expression rhs
            | assignAdd: Expression lhs "+=" Expression rhs
            | assignSub: Expression lhs "-=" Expression rhs
            | assignShl: Expression lhs "\<\<=" Expression rhs
