[1mstr[0m prettyTree(
    Tree t,
    [1mbool[0m src = [1mfalse[0m,
    [1mbool[0m characters = [1mtrue[0m,
    [1mbool[0m \layout = [1mfalse[0m,
    [1mbool[0m literals = \layout
) {
    [1mbool[0m include(appl(prod(lit(_), _, _), _)) = literals;
    [1mbool[0m include(appl(prod(cilit(_), _, _), _)) = literals;
    [1mbool[0m include(appl(prod(\layouts(_), _, _), _)) = \layout;
    [1mbool[0m include(amb({*_, appl(prod(\layouts(_), _, _), _)})) = \layout;
    [1mbool[0m include(char(_)) = characters;
    [1mdefault[0m [1mbool[0m include(Tree _) = [1mtrue[0m;
    
    [1mstr[0m nodeLabel(appl(prod(label([1mstr[0m l, Symbol nt), _, _), _))
        = "<[1mtype[0m(nt, ())> = <l>: ";
    [1mstr[0m nodeLabel(appl(prod(Symbol nt, as, _), _))
        = "<[1mtype[0m(nt, ())> = <[1mfor[0m (a <- as) {><[1mtype[0m(a, ())> <}>";
    [1mstr[0m nodeLabel(appl(error(Symbol nt, Production p, [1mint[0m dot), _))
        = "!error dot=<dot>: <nodeLabel(appl (
                                            p,
                                            []
                                        ))>";
    [1mstr[0m nodeLabel(appl(skipped(Symbol s), chars)) = "skipped";
    [1mstr[0m nodeLabel(appl(regular(Symbol nt), _)) = "<[1mtype[0m(nt, ())>";
    [1mstr[0m nodeLabel(char(32)) = "⎵";
    [1mstr[0m nodeLabel(char(10)) = "\\r";
    [1mstr[0m nodeLabel(char(13)) = "\\n";
    [1mstr[0m nodeLabel(char(9)) = "\\t";
    [1mstr[0m nodeLabel(amb(_)) = "❖";
    [1mstr[0m nodeLabel([1mloc[0m src) = "<src>";
    [1mstr[0m nodeLabel(cycle(Symbol nt, [1mint[0m len)) = "cycle(<[1mtype[0m(nt, ())>, <len>)";
    [1mdefault[0m [1mstr[0m nodeLabel(Tree v) = "<v>";
    
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges(Tree t: appl(_, [1mlist[0m[Tree] args))
        = [<"src", t@\loc> | src, t@\loc?] + [<"", k> | Tree k <- args, include(k)];
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges(amb([1mset[0m[Tree] alts)) = [<"", a> | Tree a <- alts];
    [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges([1mloc[0m _) = [];
    [1mdefault[0m [1mlrel[0m[[1mstr[0m, [1mvalue[0m] edges(Tree _) = [];
    
    [1mreturn[0m ppvalue(t, nodeLabel, edges);
}

