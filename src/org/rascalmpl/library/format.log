[1mdata[0m RuntimeException = invalid([1mstr[0m \type, [1mvalue[0m v, [1mlist[0m[[1mvalue[0m] path = []);

[1mprivate[0m [1mdata[0m RuntimeException = none();

[3m[2m@synopsis{The general and simple validation case is when a value's run-time type already matches the expected static type}[0m
[3m[2m@memo[0m
&T validate(
    [1mtype[0m[&T] expected,
    [1mvalue[0m v,
    [1mlist[0m[[1mvalue[0m] path = [],
    [1mbool[0m relaxed = [1mfalse[0m
) {
    [1mif[0m (&T x := v) {
        [1mreturn[0m x;
    }
    [1melse[0m {
        [1mfail[0m validate;
    }
}

[3m[2m@synopsis{To validate nodes we can try whether or not it can be matched to a constructor of a defined data type with the same name and (resp. validating) children.}[0m
[3m[2m@memo[0m
&T validate(
    [1mtype[0m[&T] expected,
    [1mnode[0m v,
    [1mlist[0m[[1mvalue[0m] path = [],
    [1mbool[0m relaxed = [1mfalse[0m
) {
    Symbol lookup([1mstr[0m name, [*_, label(key, sym), *_]) = sym;
    [1mdefault[0m Symbol lookup([1mstr[0m _, [1mlist[0m[Symbol] _) = \value();
    Symbol unlabel(label(_, Symbol sym)) = sym;
    [1mdefault[0m Symbol unlabel(Symbol sym) = sym;
    
    [1mif[0m (expected.symbol == \node(), &T vv := v) {
        [1mreturn[0m vv;
    }
    [1mif[0m (def: adt(_, _) := expected.symbol, grammar := expected.definitions) {
        RuntimeException msg = none();
        name = getName(v);
        children = getChildren(v);
        params = getKeywordParameters(v);
        [1mint[0m arity = size(children);
        
        candidates
            [3m[2m// first the constructors with the right name[0m
            = [<name, symbols, kwTypes>
              | /\cons(label(name, def), symbols, kwTypes, _) := grammar[def] ? {}, size(symbols) == arity]
            + [3m[2m// then the constructors with different names (only in relaxed mode)[0m
             [<other, symbols, kwTypes>
              | relaxed, /\cons(label([1mstr[0m other: !name, _), symbols, kwTypes, _) := grammar[def] ? {}, size(symbols) == arity];
        
        [3m[2m// there may be several constructors with this name; we try them all, backtracking over already validated sub-values:[0m
        [1mfor[0m (<otherName, symbols, kwTypes> <- candidates) {
            [1mtry[0m {
                [3m[2m// for the recursion it's important that we @memo the results to avoid rework in the next cycle of the surrounding for loop[0m
                children
                    = [validate(
                           [1mtype[0m(unlabel(symbols[i]), grammar), children[i],
                           path = path + [i],
                           relaxed = relaxed
                       ) | i <- index(children)];
                
                [3m[2m// similarly for recursion into the keyword parameters, we @memo this function to make sure we don't do sub-trees again and again:[0m
                params
                    = (key:
                           validate(
                               [1mtype[0m(lookup(name, kwTypes), grammar), params[key],
                               path = path + [key],
                               relaxed = relaxed
                           )
                      | key <- params
                      );
                
                [3m[2m// TODO: make a more specific and faster version of `make` that can apply a specific constructor directly[0m
                [1mreturn[0m make(expected, otherName, children, params);
            }
            [1mcatch[0m RuntimeException e: invalid(_, _): {
                msg = e;
                [1mcontinue[0m;
            }
            [1mcatch[0m RuntimeException e: IllegalArgument(_): {
                [3m[2m// pretty sure this can never happen, but `make` does potentially throw this in the general case...[0m
                msg = e;
                [1mcontinue[0m;
            }
            [1mcatch[0m RuntimeException e: IllegalArgument(_, _): {
                [3m[2m// pretty sure this can never happen, but `make` does potentially throw this in the general case...[0m
                msg = e;
                [1mcontinue[0m;
            }
        }
        
        [1mif[0m (msg != none()) {
            [1mthrow[0m msg;
        }
        [1melse[0m {
            [1mfail[0m validate;
        }
    }
    [1mfail[0m validate;
}

[3m[2m@synopsis{if a (sub)value can not be validated we report the expected type, the not-matching value and the path that led us there}[0m
[1mdefault[0m &T validate(
    [1mtype[0m[&T] expected,
    [1mvalue[0m v,
