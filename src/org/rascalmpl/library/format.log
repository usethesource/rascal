[3m[2m@synopsis{Configuration options for toBox}[0m
[1mdata[0m FormattingOptions (CaseInsensitivity ci = asIs()) = formattingOptions();

[3m[2m@synopsis{Normalization choices for case-insensitive literals.}[0m
[1mdata[0m CaseInsensitivity
    = toLower()
    | toUpper()
    | toCapitalized()
    | asIs()
    ;

[3m[2m@synopsis{This is the generic default formatter}[0m
[3m[2m@description{
This generic formatter is to be overridden by someone constructing a formatter tools
for a specific language. The goal is that this `toBox` default rule maps 
syntax trees to plausible Box expressions, and that only a minimal amount of specialization
by the user is necessary.
}[0m
[1mdefault[0m Box toBox(t: appl(Production p, [1mlist[0m[Tree] args), FO opts = fo()) {
    [3m[2m// the big workhorse switch identifies all kinds of special cases for shapes of[0m
    [3m[2m// grammar rules, and accidental instances (emptiness, only whitespace, etc.)[0m
    [1mswitch[0m(<delabel(p), args>) {
        [3m[2m// nothing should not produce additional spaces[0m
        [1mcase[0m <_, []>:
            [1mreturn[0m NULL();
        
        [3m[2m// literals are printed as-is[0m
        [1mcase[0m <prod(lit(_), _, _), _>: {
            [1mstr[0m yield = "<t>";
            [1mreturn[0m yield != "" ? L(yield) : NULL();
        }
        
        [3m[2m// case-insensitive literals are optionally normalized[0m
        [1mcase[0m <prod(cilit(_), _, _), _>: {
            [1mstr[0m yield = "<t>";
            [1mreturn[0m yield != "" ? L(ci(opts.ci, "<t>")) : NULL();
        }
        
        [3m[2m// non-existing content should not generate accidental spaces[0m
        [1mcase[0m <regular(opt(_)), []>:
            [1mreturn[0m NULL();
        
        [1mcase[0m <regular(opt(_)), [Tree present]>:
            [1mreturn[0m U([toBox(present)]);
        
        [3m[2m// non-separated lists should stick without spacing (probably lexical)[0m
        [1mcase[0m <regular(iter(_)), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// non-separated lists should stick without spacing (probably lexical)[0m
        [1mcase[0m <regular(\iter-star(_)), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// comma's are usually for parameters separation. leaving it to[0m
        [3m[2m// parent to wrap the box in the right context.[0m
        [1mcase[0m <regular(\iter-seps(_, [_, lit(","), _])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                U(
                    [H([ toBox(elements[i], opts = opts), [3m[2m// element[0m
                                                         *[L(",") | i + 2 < size(elements)] [3m[2m// separator[0m
                                                                                            ], hs = 0 )
                    | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [3m[2m// comma's are usually for parameters separation[0m
        [1mcase[0m <regular(\iter-star-seps(_, [_, lit(","), _])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                HV(
                    [H([ toBox(elements[i], opts = opts), [3m[2m// element[0m
                                                         *[L(",") | i + 2 < size(elements)] [3m[2m// separator[0m
                                                                                            ], hs = 0 )
                    | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [3m[2m// semi-colons are usually for statement separation[0m
        [1mcase[0m <regular(\iter-seps(_, [_, lit(";"), _])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                V(
                    [H([ toBox(elements[i], opts = opts), [3m[2m// element[0m
                                                         *[L(";") | i + 2 < size(elements)] [3m[2m// separator[0m
                                                                                            ], hs = 0 )
                    | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [3m[2m// optional semi-colons also happen often[0m
        [1mcase[0m <regular(\iter-seps(_, [_, opt(lit(";")), _])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                V(
                    [H([
                         toBox(elements[i], opts = opts),
                         [3m[2m// element[0m
                         *[toBox(elements[i + 2]) | i + 2 < size(elements)]
                         [3m[2m// separator[0m
                         ],
                         hs = 0
                     ) | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [1mcase[0m <regular(\iter-star-seps(_, [_, lit(";"), _])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                V(
                    [H([ toBox(elements[i], opts = opts), [3m[2m// element[0m
                                                         *[L(";") | i + 2 < size(elements)] [3m[2m// separator[0m
                                                                                            ], hs = 0 )
                    | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [3m[2m// optional semi-colons also happen often[0m
        [1mcase[0m <regular(\iter-star-seps(_, [_, opt(lit(";")), _])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                V(
                    [H([
                         toBox(elements[i], opts = opts),
                         [3m[2m// element[0m
                         *[toBox(elements[i + 2]) | i + 2 < size(elements)]
                         [3m[2m// separator[0m
                         ],
                         hs = 0
                     ) | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [3m[2m// now we have any other literal as separator[0m
        [1mcase[0m <regular(\iter-seps(_, [layouts(_), lit(_), layouts(_)])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                U(
                    [H([
                         toBox(elements[i], opts = opts),
                         [3m[2m// element[0m
                         *[toBox(elements[i + 2]) | i + 2 < size(elements)]
                         [3m[2m// separator[0m
                         ],
                         hs = 0
                     ) | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [1mcase[0m <regular(\iter-star-seps(_, [layouts(_), lit(_), layouts(_)])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m
                U(
                    [H([
                         toBox(elements[i], opts = opts),
                         [3m[2m// element[0m
                         *[toBox(elements[i + 2]) | i + 2 < size(elements)]
                         [3m[2m// separator[0m
                         ],
                         hs = 0
                     ) | [1mint[0m i <- [0,4.. size(elements)]]
                );
        
        [3m[2m// this is a normal list[0m
        [1mcase[0m <regular(\iter-seps(_, [layouts(_)])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m U([toBox(elements[i], opts = opts) | [1mint[0m i <- [0,2.. size(elements)]]);
        
        [3m[2m// this is likely a lexical[0m
        [1mcase[0m <regular(\iter-seps(_, [!layouts(_)])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// this is likely a lexical[0m
        [1mcase[0m <regular(\iter(_)), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// this is a normal list[0m
        [1mcase[0m <regular(\iter-star-seps(_, [layouts(_)])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m U([toBox(elements[i], opts = opts) | [1mint[0m i <- [0,2.. size(elements)]]);
        
        [3m[2m// this is likely a lexical[0m
        [1mcase[0m <regular(\iter-star-seps(_, [!layouts(_)])), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// this is likely a lexical[0m
        [1mcase[0m <regular(\iter-star(_)), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// We remove all layout node positions to make the number of children predictable[0m
        [3m[2m// Comments can be recovered by `layoutDiff`. By not recursing into layout[0m
        [3m[2m// positions `toBox` becomes more than twice as fast.[0m
        [1mcase[0m <prod(layouts(_), _, _), [1mlist[0m[Tree] _content>:
            [1mreturn[0m NULL();
        
        [3m[2m// lexicals are never split in pieces[0m
        [1mcase[0m <prod(lex(_), _, _), _>: {
            [1mstr[0m yield = "<t>";
            [1mreturn[0m yield != "" ? L(yield) : NULL();
        }
        
        [3m[2m// Now we will deal with a lot of cases for expressions and block-structured statements.[0m
        [3m[2m// Those kinds of structures appear again and again as many languages share inspiration[0m
        [3m[2m// from their pre-decessors.[0m
        [3m[2m// binary operators become flat lists[0m
        [1mcase[0m <prod(sort([1mstr[0m x), [sort(x), layouts(_), lit([1mstr[0m op), layouts(_), sort(x)], _), [1mlist[0m[Tree] elements>:
            [1mreturn[0m U([toBox(elements[0]), L(op), toBox(elements[[1m-[0m1])]);
        
        [3m[2m// postfix operators stick[0m
        [1mcase[0m <prod(sort([1mstr[0m x), [sort(x), _, lit(_)], _), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// prefix operators stick[0m
        [1mcase[0m <prod(sort([1mstr[0m x), [lit(_), _, sort(x)], _), [1mlist[0m[Tree] elements>:
            [1mreturn[0m H([toBox(e, opts = opts) | e <- elements], hs = 0);
        
        [3m[2m// brackets stick[0m
