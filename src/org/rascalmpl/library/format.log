[1msyntax[0m AFun
    = Quoted: StrCon
    | Unquoted: IdCon
    ;

[1msyntax[0m ATerm
    = Int: IntCon
    | Real: RealCon
    | Fun: AFun
    | Appl: AFun "(" {ATerm ","}+ ")"
    | Placeholder: "\<" ATerm "\>"
    | List: "[" {ATerm ","}* "]"
    | Annotated: ATerm Annotation
    ;

[1msyntax[0m Annotation = Default: "{" {ATerm ","}+ "}";

[1msyntax[0m IntCon
    = Natural: NatCon
    | Positive: "+" NatCon
    | Negative: "-" NatCon
    ;

[1msyntax[0m RealCon = RealCon: IntCon "." NatCon OptExp;

[1msyntax[0m OptExp
    = Present: "e" IntCon
    | Absent:
    ;

[1mlexical[0m NatCon = Digits: [0[1m-[0m9]+ !>> [0[1m-[0m9];

[1mlexical[0m StrChar
    = NewLine: [\\] [n]
    | Tab: [\\] [t]
    | Quote: [\\] [\"]
    | Backslash: [\\] [\\]
    | Decimal: [\\] [0[1m-[0m9] [0[1m-[0m9] [0[1m-[0m9]
    | Normal: ![\n\t\"\\]
    ;

[1mlexical[0m StrCon = Default: [\"] StrChar* [\"];

[1mlexical[0m IdCon = Default: [A[1m-[0mZa[1m-[0mz] [A[1m-[0mZa[1m-[0mz\-0[1m-[0m9]* !>> [A[1m-[0mZa[1m-[0mz\-0[1m-[0m9];
