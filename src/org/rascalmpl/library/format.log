[3m[2m// with multiple blocks of statements, like if-then-else and try-catch-finally.[0m
Box blockOpen(Statement s) = s [1mis[0m nonEmptyBlock ? L("{") : NULL();

Box blockClose(Statement s) = s [1mis[0m nonEmptyBlock ? L("}") : NULL();

Box indentedBlock((Statement) `{<Statement+ st>}`)
    = I(toClusterBox([s | s <- st]));

[1mdefault[0m Box indentedBlock(Statement s) = I(toBox(s));

