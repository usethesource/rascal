The start symbols of g1 will be the start symbols of the resulting grammar.
}[0m
[1mpublic[0m Grammar compose(Grammar g1, Grammar g2) {
    [1mfor[0m (s <- g2.rules)
        [1mif[0m (g1.rules[s]?)
            g1.rules[s] = choice(s, {g1.rules[s], g2.rules[s]});
        [1melse[0m
            g1.rules[s] = g2.rules[s];
    g1.starts += g2.starts;
    
    reduced_rules = ();
    [1mfor[0m (s <- g1.rules) {
        c = g1.rules[s];
        [1mif[0m (c [1mis[0m choice) {
            c.alternatives
