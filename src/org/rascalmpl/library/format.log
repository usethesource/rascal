        && (m [1m-[0m ("1" : "1")).b == {2, 3};
}
[1mtest[0m [1mbool[0m testDynamicTypes2() {
    [1mmap[0m[[1mvalue[0m a, [1mvalue[0m b] m1 = ("1" : "1",
                                2   : 2,
                                3   : 3);
    [1mmap[0m[[1mvalue[0m a, [1mvalue[0m b] m2 = (2 : 2,
                                3 : 3);
    [1mreturn[0m [1mmap[0m[[1mint[0m, [1mint[0m] _ := m1 & m2 && (m1 & m2).a == {2, 3} && (m2 & m1).b == {2, 3};
}
