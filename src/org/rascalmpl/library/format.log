[3m[2m// ----- unescape -----[0m
[3m[2m// Take a string constant and replace all escaped characters by the character itself.[0m
[3m[2m// Unescape on Symbols. Note that the function below can currently coexist with the two unescape functions[0m
[3m[2m// since StrCon and SingleQuotedStrCons are *not* a subtype of Symbol (which they should be).[0m
[3m[2m// Do a deep match (/) to skip the chain function that syntactically includes both subtypes in Symbol.[0m
[1mprivate[0m [1mstr[0m unescape(Sym s) {
    [1mif[0m (/SingleQuotedStrCon scon := s) {
        [1mreturn[0m unescape(scon);
    }
    [1mif[0m (/StrCon scon := s) {
        [1mreturn[0m unescape(scon);
    }
    [1mthrow[0m "unexpected string format: <s>";
}

[1mpublic[0m [1mstr[0m unescape(StrCon s) {
    [1mif[0m ([StrCon] /^\"<chars:.*>\"$/ := s)
        [1mreturn[0m unescapeStr(chars);
    [1mthrow[0m "unexpected string format: <s>";
}

[1mprivate[0m [1mstr[0m unescape(SingleQuotedStrCon s) {
    [1mif[0m ([SingleQuotedStrCon] /^\'<chars:.*>\'$/ := s)
        [1mreturn[0m unescapeStr(chars);
    [1mthrow[0m "unexpected string format: <s>";
}

