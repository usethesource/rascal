[3m[2m@synopsis{simulates grouping as-if done from the back, by starting to peel off the rest instead of grouping the rest at the end}[0m
[1mpublic[0m
[1mlist[0m[Box] groupBy([1mlist[0m[Box] boxes, [1mint[0m gs, Box op, [1mtrue[0m)
    = [
          op[boxes = boxes[..size(boxes) [1mmod[0m gs]],
          *groupBy(boxes[size(boxes) [1mmod[0m gs..], gs, op)
