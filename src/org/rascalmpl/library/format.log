[1mpublic[0m SDF loadSDF2Module([1mstr[0m name, PathConfig pcfg) {
    [1mset[0m[Module] modules = {};
    [1mset[0m[[1mstr[0m] newnames = {name};
    [1mset[0m[[1mstr[0m] done = {};
    
    [1mwhile[0m(newnames != {}) {
        <n, newnames> = takeOneFrom(newnames);
        
        [1mif[0m (n [1mnotin[0m done) {
            file = getSearchPathLoc(n + ".sdf", pcfg);
            \mod = parse(#[1mstart[0m[Module], file).top;
            modules += \mod;
            newnames += getImports(\mod);
            done += {n};
        }
    }
    
    def = "definition
          '
          '<[1mfor[0m (Module m <- modules) {>
          '<m><}>";
    
    [1mreturn[0m parse(#SDF, def);
}

