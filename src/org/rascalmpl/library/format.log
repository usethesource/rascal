    [1mbool[0m allowAmbiguity = [1mfalse[0m,
    [1mint[0m maxAmbDepth = 2,
    [1mbool[0m allowRecovery = [1mfalse[0m,
    [1mint[0m maxRecoveryAttempts = 30,
    [1mint[0m maxRecoveryTokens = 3,
