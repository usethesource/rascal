[1mmodule[0m analysis::flow::ObjectFlow

[1mimport[0m List;
[1mextend[0m analysis::graphs::Graph;

[1mdata[0m FlowProgram = flowProgram([1mset[0m[FlowDecl] decls, [1mset[0m[FlowStm] statements);

[1mpublic[0m [1mloc[0m emptyId = |id:///| ;

[3m[2m@synopsis{Figure 2.1}[0m
[1mdata[0m FlowDecl
    = attribute([1mloc[0m id)
    | method([1mloc[0m id, [1mlist[0m[[1mloc[0m] formalParameters)
    | constructor([1mloc[0m id, [1mlist[0m[[1mloc[0m] formalParameters)
