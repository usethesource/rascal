    [1mif[0m (!exists(l) || !isDirectory(l)) {
        [1mtry[0m {
            println("\tcontents: <l.ls>");
            [1massert[0m
            [1mfalse[0m : "ls on a non-directory should have thrown an IO exception";
        }
