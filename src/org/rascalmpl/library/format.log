[1mpublic[0m Production optimizeLookaheads(Symbol rhs, [1mset[0m[Production] alts) {
    [1mlist[0m[CharRange] l = [];
    
    [3m[2m// first we identify which unique ranges there are for all the different productions[0m
    [1mfor[0m (lookahead(_, [1mset[0m[Symbol] classes, Production _) <- alts) {
        [1mfor[0m (\char-class(rs) <- classes, r <- rs) {
            [3m[2m// find the first range that is not smaller than the pivot[0m
            [1mif[0m ([*pre, *post] := l, [1mall[0m(z <- post, !lessThan(z, r)) || post == []) {
                [3m[2m// find all ranges that overlap with the pivot[0m
                [1mif[0m ([*overlapping, *post2] := post, [1mall[0m(\o <- overlapping, intersect(r, \o) != \empty-range()))
                {
                    [3m[2m// overlapping with existing ranges (contained in 'overlap')[0m
                    common = intersection (
                                 overlapping,
                                 [r]
                             );
                    onlyR = difference([r], overlapping);
                    onlyOverlapping = difference (
                                          overlapping,
                                          [r]
                                      );
                    l = pre + order(onlyR + common + onlyOverlapping) + post2;
                }
                [1melse[0m {
                    [3m[2m// not overlapping with existing ranges[0m
                    l = pre + [r] + post;
                }
            }
            [1melse[0m {
                println("does this ever happen? <r> and <l>");
                l = [r] + l;
            }
        }
    }
    
    [3m[2m// second part; map productions into the ranges[0m
    [1mmap[0m[CharRange range, [1mset[0m[Production] prods] m = ();
    [1mset[0m[Production] init = {};
    [1mfor[0m (lookahead(_, [1mset[0m[Symbol] classes, Production p) <- alts, \char-class(rs) <- classes) {
        [1mfor[0m (CharRange r <- l) {
            [1mif[0m (intersection([r], rs) != []) {
                m[r] ? init += {p};
            }
        }
    }
    
    [3m[2m// third part, group by ranges that predict the same set of productions[0m
    [1mmap[0m[[1mset[0m[Production] prod, [1mset[0m[CharRange] range] mInv = ();
    [1mset[0m[CharRange] init2 = {};
    [1mfor[0m (<r, s> <- m<range,prods>) {
        mInv[s] ? init2 += {r};
    }
    
    endOfInputClasses = {p| lookahead(_, classes, p) <- alts, eoi() [1min[0m classes};
    
    [1mreturn[0m
        choice(
            rhs,
            {lookahead(rhs, {\char-class([r | r <- mInv[s]])}, choice(rhs, s))| s <- mInv}
            + ((endOfInputClasses != {})
                   ? {lookahead(rhs, {eoi()}, choice(rhs, endOfInputClasses))}
