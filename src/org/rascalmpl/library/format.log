[1malias[0m OFG = [1mrel[0m[[1mloc[0m from, [1mloc[0m to];

[3m[2m@synopsis{Figure 2.2}[0m
OFG buildFlowGraph(FlowProgram p)
    = {<as[i], fps[i]>
      | newAssign(_, _, c, as) <- p.statements, constructor(c, fps) <- p.decls, i <- index(as)
      }
    + {<cl + "this", x>| newAssign(x, cl, _, _) <- p.statements}
    + {<y, x>| assign(x, _, y) <- p.statements}
    + {<as[i], fps[i]>
      | call(_, _, _, m, as) <- p.statements, method(m, fps) <- p.decls, i <- index(as)
      }
    + {<y, m + "this">| call(_, _, y, m, _) <- p.statements}
    + {<m + "return", x>| call(x, _, _, m, _) <- p.statements, x != emptyId};

[3m[2m@synopsis{Section 2.4}[0m
[1mrel[0m[[1mloc[0m, &T] propagate(OFG g, [1mrel[0m[[1mloc[0m, &T] gen, [1mrel[0m[[1mloc[0m, &T] kill, [1mbool[0m back) {
    [1mrel[0m[[1mloc[0m, &T] IN = {};
    [1mrel[0m[[1mloc[0m, &T] OUT = gen + (IN [1m-[0m kill);
    [1mif[0m (!back) {
        g = g<to,from>;
