[1mprivate[0m
[1mstr[0m ppvalue([1mvalue[0m e, [1mstr[0m([1mvalue[0m) nodeLabel, [1mlrel[0m[[1mstr[0m, [1mvalue[0m]([1mvalue[0m) edges)
