[3m[2m// unescapeStr: do the actual unescaping on a string[0m
[3m[2m// Also takes care of escaping of < and > characters as required for Rascal strings (TO DO/CHECK)[0m
[1mpublic[0m [1mstr[0m unescapeStr([1mstr[0m chars) {
    [1mreturn[0m
        [1mvisit[0m(chars) {
            [1mcase[0m /^\\b/ => "\b"
            [1mcase[0m /^\\t/ => "\t"
            [1mcase[0m /^\\n/ => "\n"
            [1mcase[0m /^\\f/ => "\f"
            [1mcase[0m /^\\r/ => "\r"
            [1mcase[0m /^\\\'/ => "\'"
            [1mcase[0m /^\\"/ => "\""
            [1mcase[0m /^\\\\/ => "\\"
            [1mcase[0m /^\\TOP/ => "\u00FF"
            [1mcase[0m /^\\EOF/ => "\u00A0"
            [1mcase[0m /^\\BOT/ => "\u0000"
            [1mcase[0m /^\\LABEL_START/ => "\u00A1"
            [1mcase[0m /^\</ => "\<"
            [1mcase[0m /^\>/ => "\>"
        }
    ;
}

