[3m[2m@synopsis{Option inheritance layer; then continue with the next box.}[0m
[3m[2m@description{
The next box is either configured by itself. Options are transferred from the
box to the opts parameter for easy passing on to recursive calls.
}[0m
[1mprivate[0m
Text \continue(Box b, Box c, Options opts, [1mint[0m m)
    = continueWith(b, c, opts[hs = b.hs][vs = b.vs][is = (b.is?) ? b.is : opts.is], m);

[3m[2m/* ------------------------------- Alignment ------------------------------------------------------------*/[0m[3m[2m@synopsis{This is to store the result of the first pass of the algorithm over all the cells in an array/table}[0m
[1mdata[0m Box([1mint[0m width = 0, [1mint[0m height = 1);

[3m[2m@synopsis{Completely layout a box and then measure its width and height, and annotate the result into the Box}[0m
[1mprivate[0m Box boxSize(Box b, Box c, Options opts, [1mint[0m m) {
    Text s = \continue(b, c, opts, m);
    b.width = twidth(s);
    b.height = size(s);
    [1mreturn[0m b;
}

[1mprivate[0m [1mlist[0m[[1mlist[0m[Box]] RR([1mlist[0m[Row] bl, Box c, Options opts, [1mint[0m m) {
    [1mlist[0m[[1mlist[0m[Box]] g = [b | R([1mlist[0m[Box] b) <- bl];
    [1mreturn[0m [[boxSize(z, c, opts, m) | Box z <- b] | [1mlist[0m[Box] b <- g];
}

[3m[2m@synopsis{Compute the maximum number of columns of the rows in a table}[0m
[1mprivate[0m
[1mint[0m Acolumns([1mlist[0m[Row] rows)
    = ( 0 | max([1mit[0m, size(row.cells)) | row <- rows );

[3m[2m@synopsis{Compute the maximum cell width for each column in an array}[0m
[1mprivate[0m
[1mlist[0m[[1mint[0m] Awidth([1mlist[0m[[1mlist[0m[Box]] rows)
    = [( 0 | max([1mit[0m, row[col].width) | row <- rows, col < size(row) )
      | [1mint[0m col <- [0..size(head(rows))]];

[3m[2m@synopsis{Adds empty cells to every row until every row has the same amount of columns.}[0m
[1mlist[0m[Row] AcompleteRows(
    [1mlist[0m[Row] rows,
    [1mint[0m columns = Acolumns(rows),
    Box rs = NULL()
)
    = [R(
           u([
               *row.cells[..[1m-[0m1],
               H_([ row.cells[[1m-[0m1], rs ], hs = 0 ),
               *[SPACE(1) | _ <- [0..columns [1m-[0m size(row.cells)]]
           ])
       ) | row <- rows[..[1m-[0m1]]
    + [
          R(
              u([*rows[[1m-[0m1].cells, *[SPACE(1) | _ <- [0..columns [1m-[0m size(rows[[1m-[0m1].cells)]]])
          )
      ];

[3m[2m@synopsis{Helper function for aligning Text inside an array cell}[0m
[1mprivate[0m
Box align(l(), Box cell, [1mint[0m maxWidth)
    = maxWidth [1m-[0m cell.width > 0 ? H_([ cell, SPACE(maxWidth [1m-[0m cell.width) ], hs = 0 ) : cell;

[3m[2m@synopsis{Helper function for aligning Text inside an array cell}[0m
[1mprivate[0m
Box align(r(), Box cell, [1mint[0m maxWidth)
    = maxWidth [1m-[0m cell.width > 0 ? H_([ SPACE(maxWidth [1m-[0m cell.width), cell ], hs = 0 ) : cell;

[1mprivate[0m
Box align(c(), Box cell, [1mint[0m maxWidth)
    = maxWidth [1m-[0m cell.width > 1
          ? H_([
                SPACE((maxWidth [1m-[0m cell.width) / 2), cell, SPACE((maxWidth [1m-[0m cell.width) / 2)
                ],
                hs = 0
            )
          : maxWidth [1m-[0m cell.width == 1 ? align(l(), cell, maxWidth) : cell;

[3m[2m// the last left box should not fill up to the right for the next non-existing column, to help implement `trimTrailingWhitespace`[0m
[1mprivate[0m Box align(fl(), Box cell, [1mint[0m maxWidth) = cell;

[3m[2m// the last center box should not fill up to the right, only to the left to help implement `trimTrailingWhitespace`[0m
[1mprivate[0m
Box align(fc(), Box cell, [1mint[0m maxWidth)
    = maxWidth [1m-[0m cell.width > 1
          ? H_([ SPACE((maxWidth [1m-[0m cell.width) / 2), cell ], hs = 0 )
          : maxWidth [1m-[0m cell.width == 1 ? align(l(), cell, maxWidth) : cell;

[1mprivate[0m
Text AA(
    [1mlist[0m[Row] table, Box c, [1mlist[0m[Alignment] alignments, Box rs, Options opts, [1mint[0m m
) {
    [1mif[0m (table == []) {
        [1mreturn[0m [];
    }
    [3m[2m// first flatten any nested U cell lists into the Rows[0m
    table = [R(u(r.cells)) | Row r <- table];
    
    [3m[2m// we remove any H-V backtracking because table cells are too small anyway, generally.[0m
    [3m[2m// so we prefer the less wide V over HOV and HV. This boosts efficiency radically, because[0m
    [3m[2m// later, ever cell will be formatted individually to an optimal width, and measured, before we even start[0m
    [3m[2m// to format the table. Then the same cells will be formatted again from scratch. By removing the[0m
    [3m[2m// backtracking, larger tables (like reified grammars) become doable.[0m
    table = [1mvisit[0m(table) {
                [1mcase[0m Box b: HOV_([1mlist[0m[Box] boxes) => V_(boxes, vs = b.vs)
                [1mcase[0m Box b: HV_([1mlist[0m[Box] boxes) => V_(boxes, vs = b.vs)
            }
    
    [3m[2m// then we can know the number of columns[0m
    [1mint[0m maxColumns = Acolumns(table);
    
    [3m[2m// then we fill each row up to the maximum of columns[0m
    [1mlist[0m[[1mlist[0m[Box]] rows
        = RR(AcompleteRows(table, columns = maxColumns, rs = rs), c, opts, m);
    
    [3m[2m// and we infer alignments where not provided[0m
    alignments = AcompleteAlignments(alignments, maxColumns);
    
    [1mif[0m (opts.trimTrailingWhitespace) {
        alignments = AfinalColumnSpecials(alignments);
    }
    [3m[2m// finally we compute alignment information[0m
    [1mlist[0m[[1mint[0m] maxWidths = Awidth(rows);
    
    [1mtry[0m {
        [3m[2m// A row is simply an H box where each cell is filled with enough spaces to align for the next column[0m
        [1mreturn[0m
            \continue(
                V_(
                    [H_([align(al, cell, mw) | <cell, al, mw> <- zip3(row, alignments, maxWidths)])
                    | row <- rows]
                ),
                c,
                opts,
                m
            );
    }
    [1mcatch[0m IllegalArgument(_, "List size mismatch"): {
        [1mthrow[0m IllegalArgument(
                  "Array alignments size is <size(alignments)> while there are <size(rows[0])> columns."
              );
    }
}

[1mprivate[0m
Text AAG(
    [], [1mint[0m _gs, [1mlist[0m[Alignment] _columns, Box _rs, Box _c, Options _opts, [1mint[0m _m
)
    = [];

[1mprivate[0m
Text AAG(
    [1mlist[0m[Box] boxes: [Box _, *_], [1mint[0m gs, [1mlist[0m[Alignment] columns, Box rs,
    Box c, Options opts, [1mint[0m m
)
    = \continue(A(groupRows(boxes, gs), columns = columns, rs = rs), c, opts, m);

[1mprivate[0m [1mlist[0m[Row] groupRows([], [1mint[0m _gs) = [];

[1mprivate[0m
[1mlist[0m[Row] groupRows([1mlist[0m[Box] boxes: [Box _, *_], [1mint[0m gs)
    = [R(boxes[..gs]), *groupRows(boxes[gs..], gs)];

[3m[2m@synopsis{Cuts off and extends the alignment spec to the width of the table}[0m
[3m[2m@description{
* if too few columns are specified: `l()`'s are added accordingly
* if too many columns are specified: they are cut off from the right
}[0m
[1mprivate[0m
[1mlist[0m[Alignment] AcompleteAlignments(
    [1mlist[0m[Alignment] alignments, [1mint[0m maxColumns
)
    = [
          *alignments[..maxColumns],
          *[l() | _ <- [0..maxColumns [1m-[0m size(alignments)]]
      ];

[3m[2m@synopsis{Translate l() and c() to fl() and fc() for the final columns to help implement `trimTrailingWhitespace`}[0m
[1mprivate[0m
[1mlist[0m[Alignment] AfinalColumnSpecials([*Alignment pre, l()])
    = [*pre, fl()];
[1mprivate[0m
[1mlist[0m[Alignment] AfinalColumnSpecials([*Alignment pre, c()])
    = [*pre, fc()];
[1mprivate[0m
[1mdefault[0m [1mlist[0m[Alignment] AfinalColumnSpecials([1mlist[0m[Alignment] as)
    = as;

[3m[2m@synopsis{Check soft limit for HV and HOV boxes}[0m
[3m[2m// TODO this seems to ignore SPACE boxes?[0m
[1mprivate[0m
[1mbool[0m noWidthOverflow([1mlist[0m[Box] hv, Options opts)
    = ( 0 | [1mit[0m + size(s) | /L(s) := hv ) < opts.wrapAfter;

[3m[2m@synopsis{Changes all HV boxes that do fit horizontally into hard H boxes.}[0m
[1mprivate[0m
Box applyHVconstraints(Box b, Options opts)
    = [1minnermost[0m [1mvisit[0m(b) {
          [1mcase[0m Box B: HV_([1mlist[0m[Box] boxes,hs = h, is = i, vs = v)
                => H_(boxes, hs = h, is = (B.is?) ? i : opts.is, vs = v)
              [1mwhen[0m noWidthOverflow(boxes, opts)
      };

[3m[2m@synopsis{Changes all HOV boxes that do fit horizontally into hard H boxes,
and the others into hard V boxes.}[0m
[1mprivate[0m
Box applyHOVconstraints(Box b, Options opts)
    = [1minnermost[0m [1mvisit[0m(b) {
          [1mcase[0m Box B: HOV_([1mlist[0m[Box] boxes,hs = h, is = i, vs = v)
              => noWidthOverflow(boxes, opts)
                     ? H_(boxes, hs = h, is = (B.is?) ? i : opts.is, vs = v)
                     : V_(boxes, hs = h, is = (B.is?) ? i : opts.is, vs = v)
      };

[3m[2m@synopsis{Workhorse, that first applies hard HV and HOV limits and then starts the general algorithm}[0m
[1mprivate[0m Text box2data(Box b, Options opts) {
    b = applyHVconstraints(b, opts);
    b = applyHOVconstraints(b, opts);
    [1mreturn[0m
        \continue(
            b,
            V_([]),
            options(
                is = opts.is,
                insertSpaces = opts.insertSpaces,
                trimTrailingWhitespace = opts.trimTrailingWhitespace
            ),
            opts.maxWidth
        );
}

