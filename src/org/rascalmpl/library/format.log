[1mimport[0m analysis::diff::edits::HiFiLayoutDiff;
[1mimport[0m analysis::diff::edits::TextEdits;
[1mimport[0m lang::box::\syntax::Box;
[1mimport[0m lang::box::util::Box2Text;
[1mimport[0m util::Formatters;
[1mimport[0m util::Reflective;

[3m[2m@synopsis{Format any Rascal module and dump the result as a string}[0m
[1mvoid[0m debugFormatRascalFile(
    [1mloc[0m \module,
    [1mbool[0m console = [1mfalse[0m,
    [1mbool[0m HTML = !console,
    FormattingOptions opts = formattingOptions(),
    [1mbool[0m dumpEdits = [1mfalse[0m
) {
    debugFileFormat(
        #[1mstart[0m[Module], toBox, \module,
        console = console,
        HTML = HTML,
        opts = opts,
        dumpEdits = dumpEdits
