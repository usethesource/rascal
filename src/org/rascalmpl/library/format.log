    [1mmap[0m[&T, [1mint[0m] low = ();      [3m[2m// smallest index of any node known to be reachable from v[0m
    [1mmap[0m[&T, [1mint[0m] indexOf = ();  [3m[2m// maps nodes to their index[0m
    [1mset[0m[&T] onStack = {};       [3m[2m// set of nodes on current stack[0m
    [1mlist[0m[&T] stack = [];        [3m[2m// node stack contains nodes of SCC under construction[0m
    
    [1mset[0m[[1mset[0m[&T]]components = {};[3m[2m// set of SCCs to be constructed[0m
    [1mlist[0m[&T] topsort = [];      [3m[2m// sorted list of elements[0m
    
    [1mvoid[0m strongConnect(&T v){
        [3m[2m// Set the depth index for v to the smallest unused index[0m
        indexOf[v] = index;
        low[v] = index;
        index += 1;
        stack = push(v, stack);
        onStack += {v};
        
        [3m[2m// Consider successors of v[0m
        [1mfor[0m(&T w <- successors(g, v)){
            [1mif[0m(!indexOf[w]?){
              [3m[2m// Successor w has not yet been visited; recurse on it[0m
              strongConnect(w);
              low[v] = min(low[v], low[w]);
