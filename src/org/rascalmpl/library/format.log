[1mpublic[0m [1mset[0m[Symbol] getConditions(SDF m) {
    res = {};
    [1mvisit[0m(m) {
        [1mcase[0m (Grammar) `restrictions <Restriction* rests>`:
            res += getRestrictions(rests, [1mtrue[0m);
        [1mcase[0m (Grammar) `lexical restrictions <Restriction* rests>`:
            res += getRestrictions(rests, [1mtrue[0m);
        [1mcase[0m (Grammar) `context-free restrictions <Restriction* rests>`:
            res += getRestrictions(rests, [1mfalse[0m);
        [1mcase[0m (Prod) `<Syms _> -\> <Sym sym> {<{Attribute ","}* _>, reject, <{Attribute ","}* _> }`:
            res
                += {conditional(
                        getSymbol(sym, [1mfalse[0m),
                        {\delete(keywords(getSymbol(sym, [1mfalse[0m).name + "Keywords"))}
                    ),
                    conditional(
                        getSymbol(sym, [1mtrue[0m),
                        {\delete(keywords(getSymbol(sym, [1mtrue[0m).name + "Keywords"))}
                    )};
    }
    
    [1mwhile[0m({conditional(s, cs1), conditional(s, cs2), *rest} := res)
        res = rest + {conditional(s, cs1 + cs2)};
    
    [3m[2m//iprintln(res);[0m
    [1mreturn[0m res;
}

