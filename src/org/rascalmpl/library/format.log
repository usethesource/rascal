[1malias[0m DocumentEdit = FileSystemChange;

[3m[2m@synopsis{For some FileSystemChanges we know exactly what happened.}[0m
[1mdata[0m FileSystemChange = changed([1mloc[0m file, [1mlist[0m[TextEdit] edits);

[3m[2m@synopsis{Shorthand for file changes.}[0m
