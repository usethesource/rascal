        [1melse[0m {
            rules[t] = choice(t, {p});
        }
    }
    [1mreturn[0m grammar(starts, rules);
}

Grammar grammar([1mtype[0m[&T <: Tree] sym)
    = grammar({sym.symbol}, sym.definitions);

[3m[2m@synopsis{An item is an index into the symbol list of a production rule.}[0m
