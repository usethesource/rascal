[1mprivate[0m Text HH([], Box _, Options _opts, [1mint[0m _m) = [];

[1mprivate[0m Text HH([1mlist[0m[Box] b: [_, *_], Box _, Options opts, [1mint[0m m) {
    Text r = [];
    b = reverse(b);
    [1mfor[0m (a <- b) {
        Text t = \continue(a, H([]), opts, m);
        [1mint[0m s = hwidth(t);
        r = hh(t, rhh(hskip(opts.hs, opts), r, opts), opts);
        m = m [1m-[0m s [1m-[0m opts.hs;
    }
    
    [1mreturn[0m r;
}

[1mprivate[0m
Text GG(
