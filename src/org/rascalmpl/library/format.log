        );
}

[1mpublic[0m Production optimizeLookaheadsOld(Symbol rhs, [1mset[0m[Production] alts) {
    [1msolve[0m(alts) {
        [1mfor[0m (a: lookahead(_, c1, p1) <- alts, b: lookahead(_, c2, p2) <- alts, a != b) {
            [1mif[0m (c1 == c2) {
