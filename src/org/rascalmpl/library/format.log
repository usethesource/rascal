[3m[2m@synopsis{Compute a relation from extender to extended module for the given grammar}[0m
[3m[2m@description{
Note that this relation is already transitively closed because that is the semantics of extend.
}[0m
[1mrel[0m[[1mstr[0m \module, [1mstr[0m extended] extends(GrammarDefinition def) {
    [1mreturn[0m
        {<m, e>| m <- def.modules, \module(_, _, exts, _) := def.modules[m], e <- exts}+;
}

[3m[2m@synopsis{Compute a relation from importer to imported modules for the given grammar}[0m
[1mrel[0m[[1mstr[0m \module, [1mstr[0m imported] imports(GrammarDefinition def) {
    [1mreturn[0m
        {<m, i>| m <- def.modules, \module(_, imps, _, _) := def.modules[m], i <- imps};
}

[3m[2m@synopsis{Compute which modules directly depend on which other modules.}[0m
[3m[2m@description{
This function computes dependencies via import and extend relations. Every module
X that imports Y or extends Y ends up in the result as <X, Y>. The extends relation
that we use is already transitively closed. Next to this we also add dependencies
<X, Z> for all modules X that import Y which extends Z. Because of the transitive
nature of module extension, a module that extends another module exposes all
rules to any importing module. 
}[0m
[1mrel[0m[[1mstr[0m \module, [1mstr[0m dependency] dependencies(GrammarDefinition def) {
    imps = imports(def);
    exts = extends(def);
    
    [1mreturn[0m imps + exts + imps [1mo[0m exts;
}
