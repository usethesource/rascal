[1mjava[0m [1mvalue[0m readXML(
    [1mloc[0m file,
    [1mbool[0m fullyQualify = [1mfalse[0m,
    [1mbool[0m trackOrigins = [1mfalse[0m,
    [1mbool[0m includeEndTags = [1mfalse[0m,
    [1mbool[0m ignoreComments = [1mtrue[0m,
    [1mbool[0m ignoreWhitespace = [1mtrue[0m,
