[3m[2m@synopsis{Geometric mean of data values.}[0m
[3m[2m@description{
Computes the [geometric mean](http://en.wikipedia.org/wiki/Geometric_mean) of the given data values.
}[0m
[1mreal[0m geometricMean([[1mnum[0m hd, *[1mnum[0m tl]) {
    [1mif[0m (tl == []) {
        [1mreturn[0m toReal(hd);
    }
    prod = ( hd | [1mit[0m * v | v <- tl );
    [1mif[0m (prod < 0) {
        [1mthrow[0m ArithmeticException(
                  "Geometric mean can only be calculated for positive numbers"
              );
    }
    [1mif[0m (prod == 0) {
        [1mreturn[0m toReal(prod);
    }
    [1mreturn[0m nroot(prod, 1 + size(tl));
}

[3m[2m@synopsis{Kurtosis of data values.}[0m
[3m[2m@description{
Computes the [kurtosis](http://en.wikipedia.org/wiki/Kurtosis) of the given data values.
Kurtosis is a measure of the "peakedness" of a distribution.
}[0m
[1mreal[0m kurtosis([1mlist[0m[[1mnum[0m] values: [_, *_]) {
    varPow = pow(variance(values), 2);
    
    [1mif[0m (varPow == 0.) {
        [1mthrow[0m ArithmeticException(
                  "kurtosis is undefined for values with 0 variance"
              );
    }
    [1mreturn[0m centralMoment(values, order = 4) / varPow;
}

[3m[2m@synopsis{Kurtosis excess of data values.}[0m
[3m[2m@description{
Computes the [kurtosis excess](http://en.wikipedia.org/wiki/Kurtosis) of the given data values.
Kurtosis excess is a measure of the "peakedness" of a distribution corrected such that a normal distribution will be 0.
}[0m
[1mreal[0m kurtosisExcess([1mlist[0m[[1mnum[0m] values) = kurtosis(values) [1m-[0m 3;

[3m[2m@synopsis{Largest data value.}[0m
(&T <: [1mnum[0m) max([(&T <: [1mnum[0m) h, *(&T <: [1mnum[0m) t]) = ( h | [1mit[0m < n ? n : [1mit[0m | n <- t );

[3m[2m@synopsis{Arithmetic mean of data values.}[0m
[3m[2m@description{
Computes the [arithmetic mean](http://en.wikipedia.org/wiki/Arithmetic_mean) of the data values.
}[0m
[1mreal[0m mean([1mlist[0m[[1mnum[0m] nums: [_, *_]) = toReal(sum(nums)) / size(nums);

[3m[2m@synopsis{Median of data values.}[0m
[3m[2m@description{
Returns the [median](http://en.wikipedia.org/wiki/Median) of the available values.
This is the same as the 50th ((percentile)).
}[0m
[3m[2m@examples{
```rascal-shell
import analysis::statistics::Descriptive;
median([1,2,5,7,8]);
median([1,2,2,6,7,8]);
```
}[0m
[1mdefault[0m [1mreal[0m median([1mlist[0m[[1mnum[0m] nums: [_, *_]) = mean(middle(nums));

[1mprivate[0m [1mlist[0m[&T] middle([1mlist[0m[&T] nums) {
    nums = sort(nums);
    n = size(nums);
    [1mif[0m (n % 2 == 1) {
        [1mreturn[0m [nums[n / 2]];
    }
    n = n / 2;
    [1mreturn[0m nums[n [1m-[0m 1..n + 1];
}

[3m[2m@synopsis{Smallest data value.}[0m
(&T <: [1mnum[0m) min([(&T <: [1mnum[0m) h, *(&T <: [1mnum[0m) t]) = ( h | [1mit[0m > n ? n : [1mit[0m | n <- t );

[3m[2m@synopsis{Percentile of data values.}[0m
[3m[2m@description{
Returns the `p`th [percentile](http://en.wikipedia.org/wiki/Percentile) of the data values.
 0 < `p` <= 100 should hold.
}[0m
&T <: [1mnum[0m percentile([1mlist[0m[&T <: [1mnum[0m] nums, [1mnum[0m p) {
    [1mif[0m (0 > p || p > 100) {
        [1mthrow[0m IllegalArgument(p, "Percentile argument should be between 0 and 100");
    }
    nums = sort(nums);
    idx = max(1., toReal(size(nums)) * (toReal(p) / 100));
    [1mreturn[0m nums[ceil(idx) [1m-[0m 1];
}

[3m[2m@synopsis{Variance of data values.}[0m
[3m[2m@description{
Computes the [variance](http://en.wikipedia.org/wiki/Variance) of the data values.
It measures how far a set of numbers is spread out.
}[0m
[1mnum[0m variance([[1mnum[0m hd, *[1mnum[0m tl]) {
    [1mif[0m (tl == []) {
        [1mreturn[0m 0.;
    }
    [3m[2m//Compensated variant of the two pass algorithm[0m
    n = 1 + size(tl);
    mn = mean(tl + hd);
    sum2 = ( pow(hd [1m-[0m mn, 2) | [1mit[0m + pow(i [1m-[0m mn, 2) | i <- tl );
    sum3 = ( hd [1m-[0m mn | [1mit[0m + (i [1m-[0m mn) | i <- tl );
    [1mreturn[0m (sum2 [1m-[0m (pow(sum3, 2) / n)) / (n [1m-[0m 1);
}

[3m[2m@synopsis{Skewness of data values.}[0m
[3m[2m@description{
Returns the [skewness](http://en.wikipedia.org/wiki/Skewness) of the available values. Skewness is a measure of the asymmetry of a given distribution.
}[0m
[1mreal[0m skewness([1mlist[0m[[1mnum[0m] values: [_, *_])
    = centralMoment(values, order = 3) / pow(centralMoment(values, order = 2), 3 / 2);

[3m[2m@synopsis{Standard deviation of data values.}[0m
[3m[2m@description{
Computes the [standard deviation](http://en.wikipedia.org/wiki/Standard_deviation)
of the data values. It shows how much variation exists from the average (mean, or expected value).
}[0m
[1mreal[0m standardDeviation([1mlist[0m[[1mnum[0m] values) {
    [1mif[0m (values == []) {
        [1mthrow[0m IllegalArgument(
                  values, "Standard Deviation cannot be calculated for empty lists"
              );
    }
    [1mreturn[0m sqrt(variance(values));
}

[3m[2m@synopsis{Sum of data values.}[0m
[1mpublic[0m (&T <: [1mnum[0m) sum([(&T <: [1mnum[0m) hd, *(&T <: [1mnum[0m) tl]) = ( hd | [1mit[0m + i | i <- tl );

[3m[2m@synopsis{Sum of the squares of data values.}[0m
(&T <: [1mnum[0m) sumsq([1mlist[0m[&T <: [1mnum[0m] values) = sum([n * n | n <- values]);

[3m[2m@synopsis{Calculate the k-th central moment}[0m
[1mreal[0m centralMoment([1mlist[0m[[1mnum[0m] nums: [_, *_], [1mint[0m order = 1) {
    [1mif[0m (order < 0) {
        [1mthrow[0m IllegalArgument(
                  nums, "Central moment cannot be calculated for the <order>-th order."
              );
    }
    [1mif[0m (order == 0) {
        [1mreturn[0m 1.;
    }
    [1mif[0m (order == 1) {
        [1mreturn[0m 0.;
    }
    mn = mean(nums);
    [1mreturn[0m moment([n [1m-[0m mn | n <- nums], order = order);
}

[3m[2m@synopsis{Calculate the k-th moment}[0m
[1mreal[0m moment([1mlist[0m[[1mnum[0m] nums: [_, *_], [1mint[0m order = 1) {
    [1mif[0m (order < 0) {
        [1mthrow[0m IllegalArgument(
                  order, "Central moment cannot be calculated for the <order>-th order."
              );
    }
    [1mif[0m (order == 0) {
        [1mreturn[0m 1.;
    }
    [1mif[0m (order == 1) {
        [1mreturn[0m toReal(sum(nums)) / size(nums);
    }
    [1mreturn[0m ( 0. | [1mit[0m + pow(n, order) | n <- nums ) / size(nums);
}
