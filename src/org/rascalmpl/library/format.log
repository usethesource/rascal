        [1mif[0m (dt.day < 31) {
            [1mreturn[0m createDate(dt.year, dt.month, dt.day + 1);
        }
        [1melse[0m [1mif[0m (dt.month < 12) {
            [1mreturn[0m createDate(dt.year, dt.month + 1, 1);
        }
        [1melse[0m {
            [1mreturn[0m createDate(dt.year + 1, 1, 1);
        }
    }
    [1melse[0m [1mif[0m (dt.month == 2) {
        [1mif[0m (dt.day < 27) {
            [1mreturn[0m createDate(dt.year, dt.month, dt.day + 1);
        }
        [1melse[0m [1mif[0m (dt.day == 28 && ((dt.year % 400 == 0) || (dt.year % 4 == 0 && dt.year % 100 > 0))) {
            [3m[2m// leap year[0m
            [1mreturn[0m createDate(dt.year, dt.month, dt.day + 1);
        }
        [1melse[0m {
            [1mreturn[0m createDate(dt.year, dt.month + 1, 1);
        }
    }
    [1melse[0m {
        [1mif[0m (dt.day < 30) {
            [1mreturn[0m createDate(dt.year, dt.month, dt.day + 1);
        }
        [1melse[0m {
            [1mreturn[0m createDate(dt.year, dt.month + 1, 1);
        }
    }
}

[1mstr[0m formattedDate([1mdatetime[0m dt)
    = "<fill(dt.year, 4)>-<fill(dt.month)>-<fill(dt.day)>";

[1mstr[0m formattedTime([1mdatetime[0m dt)
