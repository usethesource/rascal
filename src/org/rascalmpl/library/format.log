[1mlexical[0m SingleEscapeCharacter = [\'\"\\bfnrtv];

[1mlexical[0m NonEscapeCharacter [3m[2m// SourceCharacter but not one of EscapeCharacter or LineTerminator[0m
                          = ![\n\'\"\\bfnrtv0[1m-[0m9xu];

[1mlexical[0m EscapeCharacter
