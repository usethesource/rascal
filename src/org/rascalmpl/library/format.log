by semantic processing of parse trees}[0m
[1mpublic[0m Grammar resolve(Grammar d) {
    cd = {n| \sort(n) <- d.rules};
    pcd = {n| \parameterized-sort(n, _) <- d.rules};
    lx = {n| \lex(n) <- d.rules};
    plx = {n| \parameterized-lex(n, _) <- d.rules};
    ks = {n| \keywords(n) <- d.rules};
    ls = {n| \layouts(n) <- d.rules};
    
    [1mreturn[0m
        [1mvisit[0m(d) {
            [1mcase[0m sort(n): {
                [1mif[0m (n [1min[0m lx)
                    [1minsert[0m \lex(n);
                [1mif[0m (n [1min[0m ks)
                    [1minsert[0m \keywords(n);
                [1mif[0m (n [1min[0m ls)
                    [1minsert[0m \layouts(n);
                [1mfail[0m;
            }
            [1mcase[0m \parameterized-sort(n, ps): {
                [1mif[0m (n [1min[0m plx)
                    [1minsert[0m \parameterized-lex(n, ps);
                [1mfail[0m;
            }
            [1mcase[0m lex(n): {
                [1mif[0m (n [1min[0m cd)
                    [1minsert[0m \sort(n);
                [1mif[0m (n [1min[0m ks)
                    [1minsert[0m \keywords(n);
                [1mif[0m (n [1min[0m ls)
                    [1minsert[0m \layouts(n);
                [1mfail[0m;
            }
            [1mcase[0m \parameterized-lex(n, ps): {
                [1mif[0m (n [1min[0m pcd)
                    [1minsert[0m \parameterized-sort(n, ps);
                [1mfail[0m;
            }
        }
}

[1mpublic[0m [1mstr[0m unescape([1mstr[0m name) {
    [1mif[0m (/\\<rest:.*>/ := name)
        [1mreturn[0m rest;
    [1mreturn[0m name;
}
