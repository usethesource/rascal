[3m[2m/* Modules */[0mBox toBox(Toplevel* toplevels) = toClusterBox(toplevels);

Box toBox(
    (Module) `<Tags tags> module <QualifiedName name> <Import* imports> <Body body>`
)
    = V(
          V(toBox(tags), H(L("module"), toBox(name))), toClusterBox(imports), toBox(body),
          vs = 1
      );

Box toBox(Import* imports) = toClusterBox(imports);

Box toBox((Import) `import <ImportedModule m>;`)
    = H(L("import"), H0(toBox(m), L(";")));

Box toBox((Import) `extend <ImportedModule m>;`)
    = H(L("extend"), H0(toBox(m), L(";")));

Box toBox((Visibility) ``) = NULL();

[3m[2m/* Syntax definitions */[0mBox toBox(
    (SyntaxDefinition) `<Start st> syntax <Sym defined> = <Prod production>;`
)
    = (production [1mis[0m \all || production [1mis[0m \first)
          ? V(
                H(toBox(st), L("syntax"), toBox(defined)),
                I(G(L("="), toBox(production), gs = 2, op = H([])), L(";"))
            )
          : [3m[2m// single rule case[0m
           H(
                toBox(st),
                L("syntax"),
                toBox(defined),
                L("="),
                H0(toBox(production), L(";"))
            );

Box toBox(
    (SyntaxDefinition) `lexical <Sym defined> = <Prod production>;`
)
    = (production [1mis[0m \all || production [1mis[0m \first)
          ? V(
                H(L("lexical"), toBox(defined)),
                I(G(L("="), toBox(production), gs = 2, op = H([])), L(";"))
            )
          : [3m[2m// single rule case[0m
           H(L("lexical"), toBox(defined), L("="), H0(toBox(production), L(";")));

Box toBox(
    (SyntaxDefinition) `keyword <Sym defined> = <Prod production>;`
)
    = (production [1mis[0m \all || production [1mis[0m \first)
          ? V(
                H(L("keyword"), toBox(defined)),
                I(G(L("="), toBox(production), gs = 2, op = H([])), L(";"))
            )
          : [3m[2m// single rule case[0m
           H(L("keyword"), toBox(defined), L("="), H0(toBox(production), L(";")));

Box toBox(
    (SyntaxDefinition) `<Visibility v> layout <Sym defined> = <Prod production>;`
)
    = (production [1mis[0m \all || production [1mis[0m \first)
          ? V(
                H(toBox(v), L("layout"), toBox(defined)),
                I(G(L("="), toBox(production), gs = 2, op = H([])), L(";"))
            )
          : [3m[2m// single rule case[0m
           H(
                toBox(v),
                L("layout"),
                toBox(defined),
                L("="),
                H0(toBox(production), L(";"))
            );

Box toBox((Prod) `<Prod lhs> | <Prod rhs>`)
    = U(toBox(lhs), L("|"), toBox(rhs));

Box toBox((Prod) `<Prod lhs> \> <Prod rhs>`)
    = U(toBox(lhs), L("\>"), toBox(rhs));

Box toBox((Prod) `:<Name n>`) = H0(L(":"), toBox(n));

Box toBox(
    (Prod) `<ProdModifier* modifiers> <Name name> : <Sym* syms>`
)
    = H([toBox(modifiers), H0(toBox(name), L(":")), *[toBox(s) | s <- syms]]);

Box toBox((Prod) `<ProdModifier* modifiers> <Sym* syms>`)
    = H([toBox(modifiers), *[toBox(s) | s <- syms]]);

Box toBox((Prod) `<Assoc a> (<Prod g>)`)
    = H(toBox(a), HOV(G(L("("), U(toBox(g)), L(")"), gs = 2, op = H([]))));

[3m[2m/* symbols */[0mBox toBox((Sym) `{<Sym e> <Sym sep>}*`)
    = H0(L("{"), H1(toBox(e), toBox(sep)), L("}"), L("*"));
Box toBox((Sym) `{<Sym e> <Sym sep>}+`)
    = H0(L("{"), H1(toBox(e), toBox(sep)), L("}"), L("+"));
Box toBox((Sym) `<Sym e>*`) = H0(toBox(e), L("*"));
Box toBox((Sym) `<Sym e>+`) = H0(toBox(e), L("+"));
Box toBox((Sym) `<Sym e>?`) = H0(toBox(e), L("?"));
Box toBox((Sym) `()`) = H0(L("("), L(")"));

Box toBox((Sym) `(<Sym first> <Sym+ sequence>)`)
    = H0(L("("), H1([toBox(first), *[toBox(e) | Sym e <- sequence]]), L(")"));

Box toBox((Sym) `start[<Nonterminal s>]`)
    = H0(L("start"), L("["), toBox(s), L("]"));

Box toBox((Sym) `(<Sym first> | <{Sym "|"}+ alternatives>)`)
    = H0(
          L("("),
          H1([toBox(first), *[L("|"), toBox(e) | Sym e <- alternatives]]),
          L(")")
      );

Box toBox((Class) `[<Range* ranges>]`)
    = H0([L("["), *[toBox(r) | r <- ranges], L("]")]);

Box toBox((Range) `<Char s> - <Char e>`) = H0(toBox(s), L("-"), toBox(e));

[3m[2m/* Declarations */[0mBox toBox((QualifiedName) `<{Name "::"}+ names>`) = L("<names>");

Box toBox((Tag) `@<Name n> <TagString contents>`)
    = H0(L("@"), toBox(n), toBox(contents));

Box toBox((Tag) `@<Name n> = <Expression exp>`)
    = H0(L("@"), toBox(n), L("="), toBox(exp));

Box toBox((Tag) `@<Name n>`) = H0(L("@"), toBox(n));

Box toBox(QualifiedName n) = L("<n>");

Box toBox(
    (Declaration) `<Tags t> <Visibility v> alias  <UserType user> = <Type base>;`
)
    = V(
          toBox(t),
          H(toBox(v), L("alias"), toBox(user), L("="), H0(toBox(base), L(";")))
      );

Box toBox(
    (Declaration) `<Tags tg> <Visibility v> data <UserType typ> <CommonKeywordParameters ps>;`
)
    = V(toBox(tg), H(toBox(v), L("data"), H0(toBox(typ), toBox(ps), L(";"))));

Box toBox(
    (Declaration) `<Tags tg> <Visibility v> data <UserType typ> <CommonKeywordParameters ps> = <Variant va>;`
)
    = HV(
          V(toBox(tg), H(toBox(v), L("data"), H0(toBox(typ)), toBox(ps))),
          I(H(L("="), H0(toBox(va), L(";"))))
      );

Box toBox(
    (Declaration) `<Tags tg> <Visibility v> data <UserType typ> <CommonKeywordParameters ps> = <Variant va> | <{Variant "|"}+ vs>;`
)
    = V(
          toBox(tg),
          H(toBox(v), L("data"), H0(toBox(typ)), toBox(ps)),
          I([G([L("="), toBox(va), *[L("|"), toBox(vax) | Variant vax <- vs][3m[2m// hoist the bars `|` up to the same level of `=`[0m
                                                                            ]), L(";")])
      );

Box toBox(
    (Declaration) `<Tags tags> <Visibility visibility> <Type typ> <Name name> = <Expression initial>;`
)
    = HV(
          V(toBox(tags), H1(toBox(visibility), toBox(typ), toBox(name))),
          I(HOV(G(L("="), U([toBox(initial)])))),
          L(";")
      );

Box toBox(
    (Declaration) `<Tags tags> <Visibility visibility> <Type typ> <Variable first>, <{Variable ","}+ variables>;`
)
    = HV(
          V(toBox(tags), H1(toBox(visibility), toBox(typ))),
          I(HOV(H0(toBox(first), L(",")), SL([toBox(v) | v <- variables], L(",")))),
          L(";")
      );

Box toBox((Declarator) `<Type typ> <Name name>`)
    = H1(toBox(typ), toBox(name));

Box toBox(
    (Declarator) `<Type typ> <Name name> = <Expression initial>`
