[3m[2m@synopsis{this is the main server generator for any chart value}[0m
[3m[2m@description{
Given a Chart value this server captures the value and serves it
as a JSON value to the HTML client generated by ((vis::Charts::plotHTML)).
}[0m
Response(Request) chartServer(Chart ch) {
    Response reply(get(/^\/chart/)) {
        [1mreturn[0m response(ch);
    }
    
    [3m[2m// returns the main page that also contains the callbacks for retrieving data and configuration[0m
    [1mdefault[0m Response reply(get(_)) {
        [1mreturn[0m response(writeHTMLString(plotHTML()));
    }
    
    [1mreturn[0m reply;
}

