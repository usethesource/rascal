[3m[2m// Locations library[0m
[3m[2m// Make two locations with a gap inbetween. When gap is negative they will overlap.[0m
[3m[2m// Always return a pair of locations <l1, l2> where l1 starts before l2.[0m
[1mtuple[0m[[1mloc[0m, [1mloc[0m] makeLocsWithGap([1mint[0m gap) {
    sign = gap > 0 ? 1 : [1m-[0m1;
    absgap = min(abs(gap), maxIndex / 2);
    m1 = 1 + arbInt(maxIndex [1m-[0m absgap [1m-[0m 2);
    [3m[2m// 1 <= m1 <= maxIndex - 2[0m
    m2 = m1 + sign * absgap;
    
    llen = arbInt(m1);
    l = getLoc(m1 [1m-[0m llen, m1);
    
    rlen = m2 == maxIndex ? 0 : arbInt(maxIndex [1m-[0m m2);
    r = getLoc(m2, m2 + rlen);
    
    [1mif[0m (l.offset == r.offset && r.length == 0) {
        [1mreturn[0m <r, l>;
    }
    [1melse[0m [1mif[0m (l.offset >= r.offset) {
        [1mreturn[0m <r, l>;
    }
    [1melse[0m {
        [1mreturn[0m <l, r>;
    }
}

[1mbool[0m report([1mloc[0m l1, [1mloc[0m l2, [1mbool[0m expected) {
    [1mif[0m (!expected) {
        println("Not expected: <l1>, <l2>");
        [1mreturn[0m [1mfalse[0m;
    }
    [1mreturn[0m [1mtrue[0m;
}

