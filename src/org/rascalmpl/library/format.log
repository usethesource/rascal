[3m[2m@synopsis{Figure 2.1}[0m
[1mdata[0m FlowStm
    = newAssign([1mloc[0m target, [1mloc[0m class, [1mloc[0m ctor, [1mlist[0m[[1mloc[0m] actualParameters)
    | assign([1mloc[0m target, [1mloc[0m cast, [1mloc[0m source)
