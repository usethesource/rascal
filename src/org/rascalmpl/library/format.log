distribution({<"chicken","animal">,<"bear","animal">,<"oak","plant">,<"tulip","plant">});
distribution({<"alice",2>,<"bob",3>,<"claire",5>},5);
```
}[0m
[1mpublic[0m [1mmap[0m[&T, [1mint[0m] distribution([1mrel[0m[&U event, &T bucket] input) {
    [1mmap[0m[&T, [1mint[0m] result = ();
    [1mfor[0m (<&U _, &T bucket> <- input) {
        result[bucket] ? 0 += 1;
    }
    
    [1mreturn[0m result;
}

