[3m[2m// ----- getLookaheads, getLookahead -----[0m
[1mpublic[0m [1mset[0m[Symbol] getLookaheads(Lookaheads ls) {
    [1mswitch[0m(ls) {
        [1mcase[0m (Lookaheads) `<Class c>`:
            [1mreturn[0m {getCharClass(c)};
        
        [1mcase[0m (Lookaheads) `<Class l> . <Lookaheads r>`: {
            rs = getLookaheads(r);
            [1mif[0m (size(rs) == 1)
                [1mreturn[0m {\seq([getCharClass(l), *rs])};
            [1melse[0m
                [1mreturn[0m {\seq([getCharClass(l), \alt(rs)])};
        }
        
        [1mcase[0m (Lookaheads) `<Lookaheads l> | <Lookaheads r>`:
            [1mreturn[0m getLookaheads(l) + getLookaheads(r);
        
        [1mcase[0m (Lookaheads) `(<Lookaheads l>)`:
            [1mreturn[0m getLookaheads(l);
        
        [1mdefault[0m: {
            println("Warning: ignored <ls>");
            [1mreturn[0m {};
        }
    }
}

