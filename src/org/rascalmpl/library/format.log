[3m[2m@synopsis{For ambiguity clusters an arbitrary choice is made.}[0m
[1mdefault[0m Box toBox(amb({Tree t, *Tree _}), FO opts = fo()) = toBox(t);

[3m[2m@synopsis{When we end up here we simply render the unicode codepoint back.}[0m
[1mdefault[0m Box toBox(c: char(_), FormattingOptions opts = fo()) = L("<c>");

[3m[2m@synopsis{Cycles are invisible and zero length}[0m
[1mdefault[0m Box toBox(cycle(_, _), FO opts = fo()) = NULL();

[3m[2m@synopsis{Create a V box of V boxes where the inner boxes are connected and the outer boxes are separated by an empty line.}[0m
[3m[2m@description{
This function learns from the input trees how vertical clusters were layout in the original tree.
The resulting box maintains the original clustering.
For example, such lists of declarations which are separated by a newline, remain separated after formatting with `toClusterBox`
```
int a1 = 1;
int a2 = 2;

int b1 = 3;
int b2 = 4;
```
}[0m
[3m[2m@benefits{
* many programmers use vertical clustering, or "grouping statements", to indicate meaning or intent, by not throwing this
away we are not throwing away the documentative value of their grouping efforts.
}[0m
[3m[2m@pitfalls{
* ((toClusterBox)) is one of the (very) few Box functions that use layout information from the input tree to 
influence the layout of the output formatted code. It replaces a call to ((toBox)) for that reason.
* ((toClusterBox)) does not work on separated lists, yet.
}[0m
Box toClusterBox([1mlist[0m[Tree] lst, FO opts = fo()) {
    [1mlist[0m[Box] cluster([]) = [];
    
    [1mlist[0m[Box] cluster([Tree e]) = [V([ toBox(e) ], vs = 0 )];
    
    [1mlist[0m[Box] cluster([*Tree pre, Tree last, Tree first, *Tree post])
        = [
              V([ *[toBox(p, opts = opts) | p <- pre], toBox(last, opts = opts) ], vs = 0 ),
              *cluster([first, *post])
          ]
        [1mwhen[0m first@\loc.begin.line [1m-[0m last@\loc.end.line > 1;
    
    [1mdefault[0m [1mlist[0m[Box] cluster([1mlist[0m[Tree] l)
        = [V([toBox(e, opts = opts) | e <- l], vs = 0)];
    
    [1mreturn[0m V(cluster(lst), vs = 1);
}

Box toClusterBox(&T* lst, FO opts = fo())
    = toClusterBox([e | e <- lst], opts = opts);
Box toClusterBox(&T+ lst, FO opts = fo())
    = toClusterBox([e | e <- lst], opts = opts);

[3m[2m@synopsis{Reusable way of dealing with large binary expression trees}[0m
[3m[2m@description{
1. the default `toBox` will flatten nested binary expressions to U lists.
2. the G box groups each operator with the following expression on the right hand-side,
   * given an initial element (usually L("=") or L(":=")) for the assignment operators
3. the entire list is indented in case the surrounding context needs more space
4. the net result is usually in vertical mode:
```
    = operand1
    + operand2
    + operand3
```
or in horizontal mode:
```
= operand1 + operand2 + operand3
```

By default ((toExpBox)) wraps it result in a HOV context, but you can pass
in a different `wrapper` if you like.
}[0m
Box toExpBox(Box prefix, Tree expression, Box wrapper = HOV())
    = wrapper[boxes = [G(prefix, toBox(expression), gs = 2, op = H())]];

[3m[2m@synopsis{Reusable way of dealing with large binary expression trees}[0m
[3m[2m@description{
1. the default `toBox` will flatten nested binary expressions to U lists.
2. the G box groups each operator horizontally with the following expression on the right hand-side.
4. the net result is usually in vertical mode:
```
    operand1 + operand2
    + operand3
```
or in horizontal mode:
```
operand1 + operand2 + operand3
```

By default ((toExpBox)) wraps it result in a HV context, but you can pass
in a different `wrapper` if you like.

}[0m
Box toExpBox(Tree expression, Box wrapper = HV())
    = wrapper[boxes = [G(toBox(expression), gs = 2, backwards = [1mtrue[0m, op = H())]];

[3m[2m@synopsis{Private type alias for legibility's sake}[0m
[1mprivate[0m [1malias[0m FO = FormattingOptions;

[3m[2m@synopsis{This is a short-hand for legibility's sake}[0m
[1mprivate[0m FO fo() = formattingOptions();

[3m[2m@synopsis{Implements normalization of case-insensitive literals}[0m
[1mprivate[0m [1mstr[0m ci(toLower(), [1mstr[0m word) = toLowerCase(word);
[1mprivate[0m [1mstr[0m ci(toUpper(), [1mstr[0m word) = toUpperCase(word);
[1mprivate[0m [1mstr[0m ci(toCapitalized(), [1mstr[0m word) = capitalize(word);
[1mprivate[0m [1mstr[0m ci(asIs(), [1mstr[0m word) = word;

[3m[2m@synopsis{Removing production labels helps with case distinctions on ((Symbol)) kinds.}[0m
[1mprivate[0m
Production delabel(prod(Symbol s, [1mlist[0m[Symbol] syms, [1mset[0m[Attr] attrs))
    = prod(delabel(s), [delabel(x) | x <- syms], attrs);
