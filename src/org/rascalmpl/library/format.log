[1mlexical[0m ExponentPart = [eE] SignedInteger;

[1mlexical[0m SignedInteger = [+\-]? [0[1m-[0m9]+ !>> [0[1m-[0m9];

[1mlexical[0m HexInteger = [0] [Xx] [0[1m-[0m9a[1m-[0mfA[1m-[0mF]+ !>> [a[1m-[0mzA[1m-[0mZ_];

[1mlexical[0m String
