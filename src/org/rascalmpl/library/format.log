[1mprivate[0m Text WDWD([], Box _c, Options _opts, [1mint[0m _m) = [];

[1mprivate[0m Text WDWD([Box head, *Box tail], Box c, Options opts, [1mint[0m m) {
    [1mint[0m h = head.hs ? opts.hs;
    Text t = \continue(head, c, opts, m);
    [1mint[0m s = hwidth(t);
    [1mreturn[0m
        hh(wd(t, opts), rhh(hskip(h, opts), WDWD(tail, c, opts, m [1m-[0m s [1m-[0m h), opts), opts);
}

[1mprivate[0m Text ifHOV([], Box b, Box c, Options opts, [1mint[0m m) = [];

