[1mpublic[0m
Grammar addHoles(Grammar object)
    = compose(object, grammar({}, holes(object)));

[3m[2m@synopsis{For every non-terminal in the grammar we create a rule that can recognize its hole syntax. Each hole
  is specific for a non-terminal (using its name as a literal), such that no ambiguity can arise. When parsing
  a fragment, the Rascal evaluator will generate a string that matches this generated syntax. It does so based on
  knowing the type of the variable, which is either declared internally in the '<...>' syntax, or derived by the 
  type checker.
  
  List types are treated differently. The are added as alternatives to the element type, such that an 
  arbitrary number of list variables can be elements of list patterns. To retrieve their original type, we store
  the list symbol as one of the attributes of the generated production.
  
  Another exception is made for lexicals. Since currently the type checker is not inline yet, we can not see at parse time
  which nonterminal names are lexical and which are not. Since nonterminal names are unique between lex and normal nonterminals
  we make sure that the literal that is generated is first normalized to remove all lex names.}[0m
[1mpublic[0m [1mset[0m[Production] holes(Grammar object) {
    [3m[2m// syntax N = @holeType=<N> [-1] "N" ":" [0-9]+ [-1];[0m
    [1mreturn[0m
        {regular(iter(\char-class([range(48, 57)]))), prod(
                                                          label("$MetaHole", getTargetSymbol(nont)),
                                                          [
                                                              \char-class([range(0, 0)]),
                                                              lit("<removeConditionals(denormalize(nont))>"),
                                                              lit(":"),
                                                              iter(\char-class([range(48, 57)])),
                                                              \char-class([range(0, 0)])
                                                          ],
                                                          {Attr::\tag("holeType"(nont))}
                                                      )
        [3m[2m// TODO: added qualifier to help compiler[0m
        | Symbol nont <- object.rules, quotable(nont)
        };
}

[3m[2m@synopsis{This function is called by the Rascal interpreter to generate a string that can be parsed by the rules generated by the
  holes function in this module.}[0m
[1mpublic[0m
[1mstr[0m createHole(ConcretePart hole, [1mint[0m idx)
    = createHole(hole.hole, idx);
[1mpublic[0m
[1mstr[0m createHole(ConcreteHole hole, [1mint[0m idx)
    = "\u0000<denormalize(sym2symbol(hole.symbol))>:<idx>\u0000";

[3m[2m@synopsis{In Rascal programs with type literals, it's hard to see easily if it is a lex or sort, so we "denormalize" here.
  The same goes for the introduction of layout non-terminals in lists. We do not know which non-terminal is introduced,
  so we remove this here to create a canonical 'source-level' type.}[0m
[1mprivate[0m
Symbol denormalize(Symbol s)
    = [1mvisit[0m(s) {
          [1mcase[0m \lex(n) => \sort(n)
          [1mcase[0m \iter-seps(u, [layouts(_), t, layouts(_)]) => \iter-seps (
                                                                 u,
                                                                 [t]
                                                             )
          [1mcase[0m \iter-star-seps(u, [layouts(_), t, layouts(_)])
              => \iter-star-seps (
                     u,
                     [t]
                 )
          [1mcase[0m \iter-seps(u, [layouts(_)]) => \iter(u)
          [1mcase[0m \iter-star-seps(u, [layouts(_)]) => \iter-star(u)
          [1mcase[0m \seq(ss) => seq([t | t <- ss, !(t [1mis[0m layouts)])
      };

[1mprivate[0m
Symbol removeConditionals(Symbol sym)
    = [1mvisit[0m(sym) {
          [1mcase[0m conditional(Symbol s, _) => s
      };

[3m[2m@synopsis{This is needed such that list variables can be repeatedly used as elements of the same list}[0m
[1mprivate[0m Symbol getTargetSymbol(Symbol sym) {
    [1mswitch[0m(sym) {
        [1mcase[0m Symbol::\iter(s):
            [1mreturn[0m s;
        [1mcase[0m Symbol::\iter-star(s):
            [1mreturn[0m s;
        [1mcase[0m Symbol::\iter-seps(s, _):
            [1mreturn[0m s;
        [1mcase[0m Symbol::\iter-star-seps(s, _):
            [1mreturn[0m s;
        [1mcase[0m Symbol::\opt(s):
            [1mreturn[0m s;
        [1mdefault[0m:
            [1mreturn[0m sym;
    }
}

